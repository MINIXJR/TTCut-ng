<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>TTCutSettingsMuxer</class>
 <widget class="QGroupBox" name="TTCutSettingsMuxer">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>500</width>
    <height>380</height>
   </rect>
  </property>
  <property name="title">
   <string>Multiplexing</string>
  </property>
  <layout class="QVBoxLayout">

   <!-- 1. Container je Codec — die Hauptentscheidung zuerst -->
   <item>
    <widget class="QGroupBox" name="gbCodecMuxer">
     <property name="title"><string>Container per Codec</string></property>
     <layout class="QFormLayout">
      <item row="0" column="0">
       <widget class="QLabel" name="laMpeg2Muxer">
        <property name="text"><string>MPEG-2:</string></property>
        <property name="toolTip"><string>Default container for MPEG-2 output. MKV (libav) is the default, MPG (mplex) for DVD/SVCD compatibility.</string></property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QComboBox" name="cbMpeg2Muxer">
        <property name="toolTip"><string>Default container for MPEG-2 output. MKV (libav) is the default, MPG (mplex) for DVD/SVCD compatibility.</string></property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="laH264Muxer">
        <property name="text"><string>H.264:</string></property>
        <property name="toolTip"><string>Default container for H.264 output. Only MKV available (mplex does not support H.264).</string></property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QComboBox" name="cbH264Muxer">
        <property name="toolTip"><string>Default container for H.264 output. Only MKV available (mplex does not support H.264).</string></property>
       </widget>
      </item>
      <item row="2" column="0">
       <widget class="QLabel" name="laH265Muxer">
        <property name="text"><string>H.265:</string></property>
        <property name="toolTip"><string>Default container for H.265 output. Only MKV available.</string></property>
       </widget>
      </item>
      <item row="2" column="1">
       <widget class="QComboBox" name="cbH265Muxer">
        <property name="toolTip"><string>Default container for H.265 output. Only MKV available.</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- 2. Container-Optionen — Detail-Settings für die gewählten Container -->
   <item>
    <widget class="QGroupBox" name="gbContainerDefaults">
     <property name="title"><string>Container Options</string></property>
     <layout class="QVBoxLayout">

      <!-- MPG sub-group (zuerst — älterer Container, MPEG-2-spezifisch) -->
      <item>
       <widget class="QGroupBox" name="gbMpg">
        <property name="title"><string>MPG (mplex)</string></property>
        <layout class="QFormLayout">
         <item row="0" column="0">
          <widget class="QLabel" name="laMpgTarget">
           <property name="text"><string>Mux target:</string></property>
           <property name="toolTip"><string>mplex target format (DVD, VCD, SVCD etc.). Set as the app default; can be overridden in the cut dialog.</string></property>
          </widget>
         </item>
         <item row="0" column="1">
          <widget class="QComboBox" name="cbMpgTarget">
           <property name="toolTip"><string>mplex target format (DVD, VCD, SVCD etc.). Set as the app default; can be overridden in the cut dialog.</string></property>
          </widget>
         </item>
         <item row="1" column="0">
          <widget class="QLabel" name="laMpgMode">
           <property name="text"><string>Mux mode:</string></property>
           <property name="toolTip"><string>Mux directly = run mplex immediately. Create mux script = write a shell script instead of calling directly.</string></property>
          </widget>
         </item>
         <item row="1" column="1">
          <widget class="QComboBox" name="cbMpgMode">
           <property name="toolTip"><string>Mux directly = run mplex immediately. Create mux script = write a shell script instead of calling directly.</string></property>
          </widget>
         </item>
        </layout>
       </widget>
      </item>

      <!-- MKV sub-group (zweite — neuerer/häufiger Container) -->
      <item>
       <widget class="QGroupBox" name="gbMkv">
        <property name="title"><string>MKV (libav)</string></property>
        <layout class="QHBoxLayout">
         <item>
          <widget class="QCheckBox" name="cbMkvCreateChapters">
           <property name="text"><string>Create chapters every</string></property>
           <property name="checked"><bool>true</bool></property>
           <property name="toolTip"><string>For MKV output, create chapter marks from cut points.</string></property>
          </widget>
         </item>
         <item>
          <widget class="QSpinBox" name="sbMkvChapterInterval">
           <property name="minimum"><number>1</number></property>
           <property name="maximum"><number>60</number></property>
           <property name="value"><number>5</number></property>
           <property name="suffix"><string> minutes</string></property>
           <property name="toolTip"><string>Additional automatic chapters every X minutes.</string></property>
          </widget>
         </item>
         <item>
          <spacer>
           <property name="orientation"><enum>Qt::Horizontal</enum></property>
           <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
          </spacer>
         </item>
        </layout>
       </widget>
      </item>

     </layout>
    </widget>
   </item>

   <!-- 3. Nach dem Multiplexen — Aufräum-Workflow -->
   <item>
    <widget class="QGroupBox" name="gbCommon">
     <property name="title"><string>After Multiplexing</string></property>
     <layout class="QVBoxLayout">
      <item>
       <widget class="QCheckBox" name="cbDeleteES">
        <property name="text"><string>Delete ES files after muxing</string></property>
        <property name="toolTip"><string>After a successful mux, automatically delete the intermediate ES files (.m2v/.mp2/.ac3/.264/.265).</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <item>
    <spacer>
     <property name="orientation"><enum>Qt::Vertical</enum></property>
     <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
    </spacer>
   </item>

   <item>
    <layout class="QHBoxLayout">
     <item><spacer><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property></spacer></item>
     <item>
      <widget class="QPushButton" name="btnResetDefaults">
       <property name="text"><string>Reset to defaults</string></property>
       <property name="toolTip"><string>Reset the values in this category to their factory defaults. Changes are applied only when you click OK.</string></property>
      </widget>
     </item>
    </layout>
   </item>

  </layout>
 </widget>
 <resources/>
 <connections/>
</ui>
