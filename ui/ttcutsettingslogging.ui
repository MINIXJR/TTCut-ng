 <class>TTCutSettingsLogging</class>
 <widget class="QGroupBox" name="TTCutSettingsLogging">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>500</width><height>400</height></rect>
  </property>
  <property name="title"><string>Logging</string></property>
  <layout class="QVBoxLayout">
   <item>
    <widget class="QGroupBox" name="gbLogBase">
     <property name="title"><string>Basic Logging</string></property>
     <layout class="QVBoxLayout">
      <item>
       <widget class="QCheckBox" name="cbCreateLog">
        <property name="text"><string>Create log file</string></property>
        <property name="toolTip"><string>Write a log file (path set in the 'Paths' category).</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="cbLogConsole">
        <property name="text"><string>Output to console</string></property>
        <property name="toolTip"><string>Log output to the console/terminal in addition to the file.</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="cbLogExtended">
        <property name="text"><string>Extended messages</string></property>
        <property name="toolTip"><string>Also write INFO and DEBUG messages to the log instead of only warnings and errors. Sets logLevel = ALL instead of MINIMAL.</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="gbLogPlus">
     <property name="title"><string>Advanced Logging Options</string></property>
     <layout class="QVBoxLayout">
      <item>
       <widget class="QCheckBox" name="cbLogPlusVideoIndex">
        <property name="text"><string>Video index information</string></property>
        <property name="toolTip"><string>Detailed messages while building the video index.</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="cbLogPlusFFmpegDecoder">
        <property name="text"><string>FFmpeg decoder information</string></property>
        <property name="toolTip"><string>Log FFmpeg decoder operations (seek, decode, flush) in detail.</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="cbLogPlusSmartCut">
        <property name="text"><string>Smart Cut engine information</string></property>
        <property name="toolTip"><string>Log Smart Cut pipeline details (re-encode decisions, GOP analysis, NAL patching).</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="cbLogPlusMkvMux">
        <property name="text"><string>MKV mux information</string></property>
        <property name="toolTip"><string>Log MKV muxing operations (stream setup, block writing).</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="cbLogPlusCutPipeline">
        <property name="text"><string>Cut pipeline information</string></property>
        <property name="toolTip"><string>Log the cut pipeline main path (data/ classes) in detail.</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="cbLogPlusAVStream">
        <property name="text"><string>AV stream parser information</string></property>
        <property name="toolTip"><string>Log AV stream parser operations (NAL detection, frame index building).</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="cbLogPlusUI">
        <property name="text"><string>UI event information</string></property>
        <property name="toolTip"><string>Log GUI action details (button clicks, position changes).</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="cbLogPlusLibav">
        <property name="text"><string>libav decoder/muxer information</string></property>
        <property name="toolTip"><string>Pass through libav decoder/muxer internals (very verbose).</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <spacer><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property></spacer>
