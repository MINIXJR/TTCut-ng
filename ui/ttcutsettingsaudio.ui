   <item>
    <widget class="QGroupBox" name="gbAudioOptions">
     <property name="title"><string>Audio Options</string></property>
     <layout class="QVBoxLayout">
      <item>
       <widget class="QCheckBox" name="cbNormalizeAcmod">
        <property name="text"><string>Normalise AC3 channel format at cut points</string></property>
        <property name="toolTip"><string>Normalise the AC3 channel format (acmod) at cut points. Prevents audio artefacts when the broadcaster changes within the stream (e.g. one segment is 5.1 and the next is 2.0).</string></property>
       </widget>
      </item>
      <item>
       <layout class="QFormLayout">
        <item row="0" column="0">
         <widget class="QLabel" name="laBurst">
          <property name="text"><string>Audio burst threshold (dB, 0=off):</string></property>
          <property name="toolTip"><string>Threshold for audio burst detection, in dB below the audio median. Advert audio that starts before the advert video is detected from this threshold and reported in the cut dialog.</string></property>
         </widget>
        </item>
        <item row="0" column="1">
         <widget class="QSpinBox" name="sbBurstThreshold">
          <property name="minimum"><number>-60</number></property>
          <property name="maximum"><number>0</number></property>
          <property name="suffix"><string> dB</string></property>
          <property name="toolTip"><string>Threshold for audio burst detection, in dB below the audio median. Advert audio that starts before the advert video is detected from this threshold and reported in the cut dialog.</string></property>
         </widget>
        </item>
       </layout>
      </item>
     </layout>
    </widget>
   </item>
