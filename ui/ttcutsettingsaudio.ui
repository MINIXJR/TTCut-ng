        <item row="0" column="0">
         <widget class="QLabel" name="laBurst">
          <property name="text"><string>Audio-Burst-Schwellwert (dB, 0=aus):</string></property>
          <property name="toolTip"><string>Schwellwert für Audio-Burst-Detection in dB unter dem Audio-Median. Werbe-Audio das vor dem Werbe-Video startet wird ab diesem Threshold erkannt und im Cut-Dialog gemeldet.</string></property>
         </widget>
        </item>
        <item row="0" column="1">
         <widget class="QSpinBox" name="sbBurstThreshold">
          <property name="minimum"><number>-60</number></property>
          <property name="maximum"><number>0</number></property>
          <property name="suffix"><string> dB</string></property>
          <property name="toolTip"><string>Schwellwert für Audio-Burst-Detection in dB unter dem Audio-Median. Werbe-Audio das vor dem Werbe-Video startet wird ab diesem Threshold erkannt und im Cut-Dialog gemeldet.</string></property>
         </widget>
        </item>
       </layout>
      </item>
     </layout>
    </widget>
