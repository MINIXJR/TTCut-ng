   <item>
    <widget class="QGroupBox" name="gbAudioOptions">
     <property name="title"><string>Audio-Optionen</string></property>
     <layout class="QVBoxLayout">
      <item>
       <widget class="QCheckBox" name="cbNormalizeAcmod">
        <property name="text"><string>AC3 Kanalformat an Schnitten normalisieren</string></property>
        <property name="toolTip"><string>AC3-Kanalformat (acmod) an Cut-Punkten normalisieren. Verhindert Audio-Artefakte bei Sender-Wechseln im Stream (z.B. wenn ein Segment 5.1 und das nächste 2.0 ist).</string></property>
       </widget>
      </item>
      <item>
