  <property name="title"><string>Audio &amp;&amp; Language</string></property>
  <layout class="QVBoxLayout">
   <item>
    <widget class="QGroupBox" name="gbAudioLang">
     <property name="title"><string>Language Preference</string></property>
     <layout class="QFormLayout">
      <item row="0" column="0">
       <widget class="QLabel" name="laLangPref">
        <property name="text"><string>Language order (e.g. deu,eng):</string></property>
        <property name="toolTip"><string>Comma-separated list of preferred audio languages (ISO 639-2 codes, e.g. deu,eng,fra). Controls the order of the audio tracks in the cut dialog.</string></property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QLineEdit" name="leAudioLangPref">
        <property name="placeholderText"><string>e.g. deu,eng,fra</string></property>
