        <property name="toolTip"><string>Min. zeitlicher Abstand zwischen Extra-Frame-Clustern (MPEG-2 field-picture) in Sekunden.</string></property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="laClusterOffset">
