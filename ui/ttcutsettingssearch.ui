      <item row="1" column="0">
       <widget class="QLabel" name="laPreviewPreset">
        <property name="text"><string>Encoder preset (H.264 / H.265 only):</string></property>
        <property name="toolTip"><string>Encoder preset for preview generation in H.264/H.265 Smart Cut. Faster presets = faster preview, slightly reduced quality of the re-encoded frames at cut points. No effect for MPEG-2 (mpeg2video has no preset concept; the regular encoder quality setting applies).</string></property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QComboBox" name="cbPreviewPreset">
