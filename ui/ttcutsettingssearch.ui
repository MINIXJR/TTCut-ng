 <class>TTCutSettingsSearch</class>
 <widget class="QGroupBox" name="TTCutSettingsSearch">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>500</width><height>320</height></rect>
  </property>
  <property name="title"><string>Suche &amp; Preview</string></property>
  <layout class="QVBoxLayout">
   <item>
    <widget class="QGroupBox" name="gbSearch">
     <property name="title"><string>Suche</string></property>
     <layout class="QFormLayout">
      <item row="0" column="0">
       <widget class="QLabel" name="laSearchLen">
        <property name="text"><string>Suchbereich (Sekunden):</string></property>
        <property name="toolTip"><string>Suchbereich um den Cut-Punkt für Schwarzbild-/Szenenwechsel-Suche (Sekunden).</string></property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QSpinBox" name="sbSearchIntervall">
        <property name="minimum"><number>1</number></property>
        <property name="maximum"><number>600</number></property>
        <property name="toolTip"><string>Suchbereich um den Cut-Punkt für Schwarzbild-/Szenenwechsel-Suche (Sekunden).</string></property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="laWorkers">
        <property name="text"><string>Such-Worker-Threads (0 = auto):</string></property>
        <property name="toolTip"><string>Parallele Worker-Threads für Frame-Search. 0 = automatisch (max. 4). Ab 4 Threads bei HEVC kaum noch Speedup wegen Cache-Saturation.</string></property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QSpinBox" name="sbSearchWorkerCount">
        <property name="minimum"><number>0</number></property>
        <property name="maximum"><number>16</number></property>
        <property name="toolTip"><string>Parallele Worker-Threads für Frame-Search. 0 = automatisch (max. 4). Ab 4 Threads bei HEVC kaum noch Speedup wegen Cache-Saturation.</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="gbPreview">
     <property name="title"><string>Preview</string></property>
     <layout class="QFormLayout">
      <item row="0" column="0">
       <widget class="QLabel" name="laPreviewLen">
        <property name="text"><string>Vorschau-Länge (Sekunden):</string></property>
        <property name="toolTip"><string>Länge der Preview-Clips um Cut-Punkte in Sekunden.</string></property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QSpinBox" name="spPreviewLength">
        <property name="minimum"><number>1</number></property>
        <property name="maximum"><number>600</number></property>
        <property name="toolTip"><string>Länge der Preview-Clips um Cut-Punkte in Sekunden.</string></property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="laPreviewPreset">
        <property name="text"><string>Encoder-Preset (nur H.264 / H.265):</string></property>
        <property name="toolTip"><string>Encoder-Preset für Preview-Generierung bei H.264/H.265 Smart Cut. Schnellere Presets = schnellere Vorschau, leicht reduzierte Qualität der re-encoded Frames an Cut-Punkten. Bei MPEG-2 wirkungslos (mpeg2video kennt kein Preset; das normale Encoder-Qualitäts-Setting greift).</string></property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QComboBox" name="cbPreviewPreset">
        <property name="toolTip"><string>Encoder-Preset für Preview-Generierung bei H.264/H.265 Smart Cut. Schnellere Presets = schnellere Vorschau, leicht reduzierte Qualität der re-encoded Frames an Cut-Punkten. Bei MPEG-2 wirkungslos (mpeg2video kennt kein Preset; das normale Encoder-Qualitäts-Setting greift).</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="gbCluster">
     <property name="title"><string>Defective Frame Grouping</string></property>
