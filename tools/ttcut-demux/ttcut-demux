#!/bin/bash
#
# ttcut-demux - Demux and normalize TS files for TTCut
# Similar to ProjectX for MPEG-2, but for H.264/H.265 (AVC/HEVC)
#
# Supported video codecs: H.264 (AVC), H.265 (HEVC), MPEG-2
# Supported audio codecs: MP2, AC3, EAC3 (DD+), AAC, MP3
#
# Multi-core optimization: Video and audio streams are extracted in parallel,
# audio padding also runs in parallel for all tracks.
#
# Usage: ttcut-demux [-e] [-A] [-n name] <input.ts> [output_dir]
#
#   -e  Elementary stream mode: output separate .264/.265 and audio files
#       (default: output normalized MKV with video+audio)
#

set -e

# Track all temp files/dirs we create so a failure (set -e abort, SIGINT,
# disk-full, ...) doesn't leave multi-GB junk in $OUTDIR. Files are removed;
# directories are removed recursively (via rm -rf inside the trap below).
_CLEANUP_FILES=()
_CLEANUP_DIRS=()

# Audio-gap detection (Rev 1, existing function uses hardcoded 5.0; constant for documentation)
readonly GAP_THRESHOLD_AUDIO=5.0
# Video-gap detection (Rev 2)
readonly GAP_THRESHOLD_VIDEO=1.0

_cleanup_temps() {
    local rc=$?
    if [ ${#_CLEANUP_FILES[@]} -gt 0 ]; then
        rm -f "${_CLEANUP_FILES[@]}" 2>/dev/null || true
    fi
    if [ ${#_CLEANUP_DIRS[@]} -gt 0 ]; then
        rm -rf "${_CLEANUP_DIRS[@]}" 2>/dev/null || true
    fi
    exit $rc
}
trap _cleanup_temps EXIT INT TERM

# Colors for output (disabled when stdout is not a terminal)
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    CYAN='\033[1;36m'
    NC='\033[0m'
else
    RED=''
    GREEN=''
    YELLOW=''
    CYAN=''
    NC=''
fi

info() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }
step() { echo -e "${CYAN}[STEP]${NC} $1"; }

# Map an ffprobe codec_name to the file extension we use for the demuxed
# audio track. Used by both the ES-mode and MKV-mode audio loops.
audio_ext_for_codec() {
    case "$1" in
        mp2|mp3) echo "mp2" ;;
        ac3)     echo "ac3" ;;
        eac3)    echo "eac3" ;;
        aac)     echo "aac" ;;
        *)       echo "$1" ;;
    esac
}

# Detect audio packet gaps in source TS via ffprobe.
# Output format (one gap per line):
#   <gap_start_pts_source> <gap_end_pts_source> <gap_size_ms>
# All values are SOURCE PTS (relative to TS PCR, NOT first_video_pts).
# Conversion to frame indices happens later when first_video_pts is known.
#
# Threshold: 5.0 seconds (anything smaller falls into the existing
# end-padding bucket, which handles sub-5s drift cumulatively).
detect_audio_gaps() {
    local source_ts=$1 stream_index=$2 out_file=$3
    : > "$out_file"
    ffprobe -v error -select_streams "$stream_index" -show_packets \
        -show_entries packet=pts_time "$source_ts" 2>/dev/null | \
    awk -F= -v threshold=5.0 '
        /^pts_time=/ {
            curr = $2
            if (prev != "" && curr - prev > threshold) {
                gap_size_ms = (curr - prev) * 1000
                printf "%.6f %.6f %.0f\n", prev, curr, gap_size_ms
            }
            prev = curr
        }
    ' >> "$out_file"
}

# Detect video packet gaps in source TS via ffprobe.
# Outputs to $out_file: one line per gap, "prev_pts curr_pts gap_ms"
# (all PTS values are source-PTS, NOT relative).
#
# Used by classify_audio_gap() to decide whether an audio gap is part of
# a combined A+V transport-stream loss (in which case audio repair is skipped).
#
# Args:
#   $1 = source TS file path
#   $2 = output file path (will be truncated to empty if no gaps)
detect_video_gaps() {
    local source_ts=$1 out_file=$2
    : > "$out_file"
    ffprobe -v error -select_streams v:0 -show_packets \
        -show_entries packet=pts_time "$source_ts" 2>/dev/null | \
    awk -F= -v threshold="$GAP_THRESHOLD_VIDEO" '
        /^pts_time=/ {
            curr = $2
            if (prev != "" && curr - prev > threshold) {
                gap_size_ms = (curr - prev) * 1000
                printf "%.6f %.6f %.0f\n", prev, curr, gap_size_ms
            }
            prev = curr
        }
    ' >> "$out_file"
}

# Compute how many milliseconds of silence to insert at an audio gap to keep
# A/V sync after the gap. The silence amount equals the amount of audio content
# missing that the video did NOT also lose.
#
# Algorithm:
#   silence_ms = max(0, audio_gap_size_ms - lost_video_seconds_in_audio_gap_range * 1000)
#   Where lost_video_seconds = sum of (overlap of each video-gap with the audio-gap range)
#
# Args:
#   $1 = audio gap start (source-PTS)
#   $2 = audio gap end   (source-PTS)
#   $3 = video gaps file (output of detect_video_gaps)
#   $4 = frame rate (decimal, e.g. "25" — only used for symmetry; not strictly needed here)
#
# Output (stdout): silence to insert in milliseconds, integer
compute_audio_gap_silence_ms() {
    local a_start=$1 a_end=$2 v_gaps_file=$3 _fps=$4
    local audio_gap_ms lost_video_ms silence_ms

    audio_gap_ms=$(awk "BEGIN {printf \"%.0f\", ($a_end - $a_start) * 1000}")

    if [ ! -s "$v_gaps_file" ]; then
        lost_video_ms=0
    else
        lost_video_ms=$(awk -v as="$a_start" -v ae="$a_end" '
            {
                v_start = $1
                v_end   = $2
                # Check if this video gap INTERSECTS with the audio gap range
                # (overlap > 0 → intersects). If so, count the FULL video gap size,
                # not just the overlap. The video stream loses (v_end - v_start) of
                # content regardless of how it overlaps with audio gap range.
                o_start = (v_start > as) ? v_start : as
                o_end   = (v_end   < ae) ? v_end   : ae
                if (o_end > o_start) lost += (v_end - v_start) * 1000
            }
            END { printf "%.0f", lost + 0 }
        ' "$v_gaps_file")
    fi

    silence_ms=$(( audio_gap_ms - lost_video_ms ))
    if [ "$silence_ms" -lt 0 ]; then
        silence_ms=0
    fi
    echo "$silence_ms"
}

# Repair audio file by splitting at gap positions and inserting silence.
# Multi-gap support: N gaps -> N+1 audio segments + N silence segments.
#
# Args:
#   $1 = audio file path (will be replaced with repaired version)
#   $2 = classified gap file (one line per gap: src_start src_end gap_ms silence_ms)
#        silence_ms is the amount of silence to insert at the gap position.
#        For combined A+V loss: silence_ms = audio_gap_ms - matching_video_gap_ms
#        (often a small remainder like 256ms). For audio-only loss: silence_ms ≈ gap_ms.
#        Gaps with silence_ms=0 are skipped (no audio insertion needed).
#   $3 = first_audio_pts (the SOURCE PTS where this audio track starts;
#        gap positions in the audio FILE = src_pts - first_audio_pts)
#
# Returns 0 on success, non-zero on failure (audio file untouched on error).
repair_audio_with_silence_inserts() {
    local audio_file=$1 gap_file=$2 first_audio_pts=$3
    local audio_ext="${audio_file##*.}"
    local work_dir
    work_dir="$(dirname "$audio_file")/.gap_repair_$$"
    mkdir -p "$work_dir"

    # Probe original audio properties for silence generation
    local codec sample_rate channels bitrate
    codec=$(ffprobe -v error -select_streams a:0 -show_entries stream=codec_name \
        -of default=noprint_wrappers=1:nokey=1 "$audio_file" 2>/dev/null)
    sample_rate=$(ffprobe -v error -select_streams a:0 -show_entries stream=sample_rate \
        -of default=noprint_wrappers=1:nokey=1 "$audio_file" 2>/dev/null)
    channels=$(ffprobe -v error -select_streams a:0 -show_entries stream=channels \
        -of default=noprint_wrappers=1:nokey=1 "$audio_file" 2>/dev/null)
    bitrate=$(ffprobe -v error -select_streams a:0 -show_entries stream=bit_rate \
        -of default=noprint_wrappers=1:nokey=1 "$audio_file" 2>/dev/null)

    # Defaults if probe returned nothing
    [[ "$sample_rate" =~ ^[0-9]+$ ]] || sample_rate=48000
    [[ "$channels" =~ ^[0-9]+$ ]] || channels=2
    case "$codec" in
        mp2)  [[ "$bitrate" =~ ^[0-9]+$ ]] || bitrate=192000 ;;
        ac3)  [[ "$bitrate" =~ ^[0-9]+$ ]] || bitrate=384000 ;;
        aac)  [[ "$bitrate" =~ ^[0-9]+$ ]] || bitrate=192000 ;;
    esac

    # Per-entry arrays. silence_dur is signed: positive = insert silence of
    # that many seconds at pos; negative = truncate |dur| seconds from the
    # after-part at pos.
    local -a gap_positions
    local -a gap_durations  # signed seconds
    local accumulated_collapse=0

    while IFS=' ' read -r src_start src_end gap_ms silence_ms; do
        [ -z "$src_start" ] && continue
        # silence_ms exactly 0 means pure A+V loss (no patching needed)
        if [ "${silence_ms:-0}" = "0" ]; then
            accumulated_collapse=$(awk "BEGIN {printf \"%.6f\", $accumulated_collapse + ($src_end - $src_start)}")
            continue
        fi
        local pos dur source_gap
        pos=$(awk "BEGIN {printf \"%.6f\", $src_start - $first_audio_pts - $accumulated_collapse}")
        # silence_ms is signed; dur is signed in seconds
        dur=$(awk "BEGIN {printf \"%.6f\", $silence_ms / 1000.0}")
        source_gap=$(awk "BEGIN {printf \"%.6f\", $src_end - $src_start}")
        gap_positions+=("$pos")
        gap_durations+=("$dur")
        accumulated_collapse=$(awk "BEGIN {printf \"%.6f\", $accumulated_collapse + $source_gap}")
    done < "$gap_file"

    if [ ${#gap_positions[@]} -eq 0 ]; then
        rm -rf "$work_dir"
        return 0  # nothing to do
    fi

    # Build filter_complex. For each entry decide insert vs truncate based on
    # sign of gap_durations[$i].
    #
    # Insert (dur > 0): emit pre-segment, silence, advance prev_end to pos.
    # Truncate (dur < 0): emit pre-segment, skip |dur| s from after-part by
    #                     advancing prev_end to pos + |dur|.
    local filter=""
    local n=${#gap_positions[@]}
    local prev_end=0
    local seg_count=0
    local sil_input_count=0
    local -a sil_durs   # per-silence-source duration, ordered as concat sees them
    local -a is_insert  # parallel to gap_positions: 1 = insert silence, 0 = truncate

    for ((i = 0; i < n; i++)); do
        local pos="${gap_positions[$i]}"
        local dur="${gap_durations[$i]}"
        filter+="[0:a]atrim=${prev_end}:${pos},asetpts=PTS-STARTPTS[seg${seg_count}];"
        seg_count=$((seg_count + 1))
        # Decide based on sign
        if awk "BEGIN {exit !($dur > 0)}"; then
            is_insert+=(1)
            sil_durs+=("$dur")
            sil_input_count=$((sil_input_count + 1))
            # After silence insertion, after-part still starts at pos
            prev_end="$pos"
        else
            is_insert+=(0)
            # Skip |dur| seconds: after-part starts at pos + |dur|.
            # Pass dur as awk -v variable to avoid shell expansion of negative
            # numbers producing double-minus syntax errors (e.g. -$dur with
            # dur=-0.533 expands to "--0.533").
            local abs_dur
            abs_dur=$(awk -v d="$dur" 'BEGIN {printf "%.6f", (d < 0) ? -d : d}')
            prev_end=$(awk -v p="$pos" -v a="$abs_dur" 'BEGIN {printf "%.6f", p + a}')
        fi
    done
    # Final after-part from last prev_end to EOF
    filter+="[0:a]atrim=${prev_end},asetpts=PTS-STARTPTS[seg${seg_count}];"
    seg_count=$((seg_count + 1))

    # Build concat input list. Order: seg0, [sil0 if insert], seg1, [sil1 if
    # insert], ..., seg(n-1), [sil(n-1) if insert], seg(n).
    local concat_inputs=""
    local sil_input_idx=1  # input 0 is original audio; silence inputs start at 1
    for ((i = 0; i < n; i++)); do
        concat_inputs+="[seg${i}]"
        if [ "${is_insert[$i]}" = "1" ]; then
            concat_inputs+="[${sil_input_idx}:a]"
            sil_input_idx=$((sil_input_idx + 1))
        fi
    done
    concat_inputs+="[seg${n}]"

    local total_segments=$((n + 1 + sil_input_count))
    filter+="${concat_inputs}concat=n=${total_segments}:v=0:a=1[out]"

    # Build silence -i arguments (one per insert entry)
    local silence_args=""
    for ((i = 0; i < sil_input_count; i++)); do
        local sdur="${sil_durs[$i]}"
        silence_args+=" -f lavfi -t ${sdur} -i anullsrc=r=${sample_rate}:cl=${channels}c"
    done

    # Run the single-pass re-encode
    local repaired="$work_dir/repaired.${audio_ext}"
    # shellcheck disable=SC2086  # silence_args contains intentional word-splitting
    ffmpeg -y -hide_banner -loglevel error \
        -i "$audio_file" \
        $silence_args \
        -filter_complex "$filter" \
        -map "[out]" \
        -c:a "$codec" -b:a "$bitrate" -ac "$channels" -ar "$sample_rate" \
        "$repaired" 2>>"$work_dir/repair.log" || return 1

    # Replace original
    mv "$repaired" "$audio_file"
    rm -rf "$work_dir"
    return 0
}

# Detect audio/video duration mismatches at segment boundaries in a VDR
# multi-file recording. For each internal segment transition, compute the
# difference between cumulative audio duration (with first-segment trim) and
# cumulative video duration. Emit one row per mismatched boundary in the same
# 4-field format CLASSIFIED_FILES uses (src_start src_end gap_ms silence_ms),
# so that the existing repair_audio_with_silence_inserts and audio_gap_frames=
# emission paths consume the entries unmodified.
#
# Sign convention: silence_ms > 0 means audio shorter than video at boundary
# (insert silence); silence_ms < 0 means audio longer than video (truncate).
#
# Arguments:
#   $1 = stream specifier for audio track inside the source TS (e.g. "a:0", "1")
#   $2 = audio_trim_sec for the first segment
#   $3 = first_audio_pts (audio's first PTS in source coordinates)
#   $4 = THRESHOLD_MS (mismatches below this absolute value are skipped; default 5)
#
# Output: rows on stdout, one per emitted boundary.
detect_segment_boundaries() {
    local stream_idx="$1"
    local audio_trim_sec="$2"
    local first_audio_pts="$3"
    local threshold_ms="${4:-5}"

    local cum_audio
    cum_audio=$(awk "BEGIN {printf \"%.6f\", -$audio_trim_sec}")
    local cum_video=0
    local n=${#VDR_SEGMENTS[@]}
    local i a_dur v_dur diff_ms src_start

    for ((i = 0; i < n; i++)); do
        local seg="${VDR_SEGMENTS[$i]}"
        a_dur=$(ffprobe -v error -select_streams "$stream_idx" \
            -show_entries stream=duration -of default=noprint_wrappers=1:nokey=1 \
            "$seg" 2>/dev/null | head -1)
        v_dur=$(ffprobe -v error -select_streams v:0 \
            -show_entries stream=duration -of default=noprint_wrappers=1:nokey=1 \
            "$seg" 2>/dev/null | head -1)
        if [[ ! "$a_dur" =~ ^[0-9]+\.?[0-9]*$ || ! "$v_dur" =~ ^[0-9]+\.?[0-9]*$ ]]; then
            echo "detect_segment_boundaries: ffprobe failed on segment $i ($seg)" >&2
            return 1
        fi
        cum_audio=$(awk "BEGIN {printf \"%.6f\", $cum_audio + $a_dur}")
        cum_video=$(awk "BEGIN {printf \"%.6f\", $cum_video + $v_dur}")

        if [ $i -lt $((n - 1)) ]; then
            diff_ms=$(awk "BEGIN {printf \"%.0f\", ($cum_video - $cum_audio) * 1000}")
            local abs_diff_ms
            abs_diff_ms=${diff_ms#-}
            if [ "$abs_diff_ms" -gt "$threshold_ms" ]; then
                src_start=$(awk "BEGIN {printf \"%.6f\", $first_audio_pts + $cum_audio}")
                echo "$src_start $src_start $abs_diff_ms $diff_ms"
                cum_audio=$(awk "BEGIN {printf \"%.6f\", $cum_audio + ($diff_ms / 1000.0)}")
            fi
        fi
    done
    return 0
}

# Parse arguments
ES_MODE=false
AC3FIX=true
OUTPUT_NAME=""
while getopts "ehAn:" opt; do
    case $opt in
        e) ES_MODE=true ;;
        A) AC3FIX=false ;;
        n) OUTPUT_NAME="$OPTARG" ;;
        h)
            echo "Usage: $0 [-e] [-A] [-n name] <input.ts> [output_dir]"
            echo ""
            echo "Demux and normalize H.264/H.265/MPEG-2 TS files for TTCut."
            echo "Similar to ProjectX for MPEG-2."
            echo ""
            echo "Options:"
            echo "  -e  Elementary stream mode (for TTCut workflow)"
            echo "      Output: video.264/.265/.m2v + audio.mp2/.ac3/.eac3 + info file"
            echo "      Filler NALUs are automatically stripped for H.264/H.265"
            echo "  -A  Disable AC3 header repair (enabled by default)"
            echo "      Fixes corrupt acmod field in DVB AC3 streams (stereo->5.1)"
            echo "  -n  Set output basename (default: input filename)"
            echo "      Example: -n 'Tatort' → Tatort.264, Tatort_deu.ac3, Tatort.info"
            echo ""
            echo "Default mode (without -e):"
            echo "  Output: normalized MKV with video + first audio"
            echo ""
            echo "VDR Integration:"
            echo "  If a 'marks' file exists in the input directory (from vdr-plugin-markad),"
            echo "  the markers are automatically parsed and added to the .info file."
            echo "  See: https://github.com/kfb77/vdr-plugin-markad"
            echo ""
            echo "Examples:"
            echo "  $0 input.ts                          # MKV output"
            echo "  $0 -e input.ts output_dir/           # Elementary stream output"
            echo "  $0 -e /video/rec/00001.ts .          # VDR recording (auto-concat splits)"
            echo "  $0 -e -n Tatort /video/rec/00001.ts  # VDR recording with custom name"
            echo "  $0 -eA input.ts output_dir/          # ES without AC3 header repair"
            exit 0
            ;;
        \?) error "Invalid option: -$OPTARG" ;;
    esac
done
shift $((OPTIND-1))

# Check arguments
if [ -z "$1" ]; then
    echo "Usage: $0 [-e] [-A] [-n name] <input.ts> [output_dir]"
    echo "Use -h for help."
    exit 1
fi

INPUT="$1"
ORIGINAL_INPUT="$1"  # Save original path before any modifications

# ffmpeg input expression as a bash array. Default for single-file recordings;
# overridden by the VDR multi-file detection block below to use the concat
# demuxer with a list file. ffprobe continues to use $INPUT directly.
declare -a FFMPEG_INPUT_ARGS
FFMPEG_INPUT_ARGS=(-i "$ORIGINAL_INPUT")

# Handle different extensions
BASENAME=$(basename "$INPUT")
BASENAME="${BASENAME%.*}"  # Remove any extension
OUTDIR="${2:-$(dirname "$INPUT")}"

# Check input file exists
[ -f "$INPUT" ] || error "Input file not found: $INPUT"

INPUT_DIR=$(dirname "$INPUT")

#############################################################################
# VDR MULTI-FILE DETECTION
# VDR splits recordings into 2GB segments: 00001.ts, 00002.ts, ...
# Automatically detect siblings and use ffmpeg concat protocol.
#############################################################################
VDR_MULTIFILE=false
VDR_SEGMENTS=()
INPUT_FILENAME=$(basename "$INPUT")

if [[ "$INPUT_FILENAME" =~ ^[0-9]{5}\.ts$ ]]; then
    # VDR >= 1.7.x format: 00001.ts, 00002.ts, ...
    VDR_PATTERN="[0-9][0-9][0-9][0-9][0-9].ts"
elif [[ "$INPUT_FILENAME" =~ ^[0-9]{3}\.vdr$ ]]; then
    # VDR < 1.7.x format: 001.vdr, 002.vdr, ...
    VDR_PATTERN="[0-9][0-9][0-9].vdr"
else
    VDR_PATTERN=""
fi

if [ -n "$VDR_PATTERN" ]; then
    while IFS= read -r -d '' seg; do
        VDR_SEGMENTS+=("$seg")
    done < <(find "$INPUT_DIR" -maxdepth 1 -name "$VDR_PATTERN" -print0 2>/dev/null | sort -z)

    if [ ${#VDR_SEGMENTS[@]} -gt 1 ]; then
        VDR_MULTIFILE=true
        # Build concat protocol string
        CONCAT_STR=""
        TOTAL_SIZE=0
        for seg in "${VDR_SEGMENTS[@]}"; do
            [ -n "$CONCAT_STR" ] && CONCAT_STR="${CONCAT_STR}|"
            CONCAT_STR="${CONCAT_STR}${seg}"
            seg_size=$(stat -c%s "$seg" 2>/dev/null || echo 0)
            TOTAL_SIZE=$((TOTAL_SIZE + seg_size))
        done
        INPUT="concat:${CONCAT_STR}"
        TOTAL_SIZE_GB=$(awk "BEGIN {printf \"%.1f\", $TOTAL_SIZE / 1073741824}")
        info "VDR multi-file recording detected: ${#VDR_SEGMENTS[@]} segments (${TOTAL_SIZE_GB} GB total)"
        for seg in "${VDR_SEGMENTS[@]}"; do
            info "  $(basename "$seg") ($(du -h "$seg" | cut -f1))"
        done
    fi
fi

# If -n was provided, override BASENAME
if [ -n "$OUTPUT_NAME" ]; then
    BASENAME="$OUTPUT_NAME"
fi

# Create output directory if needed
mkdir -p "$OUTDIR"

# Write concat-demuxer list file for VDR multi-file recordings. ffmpeg's
# concat: protocol mishandles PTS resets at segment boundaries (audio
# packets discarded when DTS appears to go backward); the concat demuxer
# treats each segment as a separate input and stitches them logically,
# surviving PTS resets.
if [ "$VDR_MULTIFILE" = true ]; then
    CONCAT_LIST_FILE="$OUTDIR/.concat_list_$$.txt"
    : > "$CONCAT_LIST_FILE"
    for seg in "${VDR_SEGMENTS[@]}"; do
        # realpath: list file paths must be absolute, otherwise ffmpeg's
        # concat demuxer resolves them relative to the list file's own
        # directory (OUTDIR), not the working directory of ttcut-demux.
        printf "file '%s'\n" "$(realpath "$seg")" >> "$CONCAT_LIST_FILE"
    done
    _CLEANUP_FILES+=("$CONCAT_LIST_FILE")
    FFMPEG_INPUT_ARGS=(-f concat -safe 0 -i "$CONCAT_LIST_FILE")
fi

# Initialize cleanup flag for repaired temp file
CLEANUP_REPAIRED=false

# Check for VDR marks file (markad plugin)
MARKS_FILE=""
VDR_MARKS=()

if [ -f "$INPUT_DIR/marks" ]; then
    MARKS_FILE="$INPUT_DIR/marks"
elif [ -f "$INPUT_DIR/marks.vdr" ]; then
    MARKS_FILE="$INPUT_DIR/marks.vdr"
fi

if [ -n "$MARKS_FILE" ]; then
    info "Found VDR marks file: $MARKS_FILE"

    # Parse marks file
    # Format: H:MM:SS.FF [( FRAME) [*] start|stop method ...]
    while IFS= read -r line || [ -n "$line" ]; do
        # Skip empty lines and comments
        [[ -z "$line" || "$line" =~ ^# ]] && continue

        # Extract timestamp (first field, format H:MM:SS.FF)
        timestamp=$(echo "$line" | grep -oE '^[0-9]+:[0-9]{2}:[0-9]{2}\.[0-9]{2}')
        [ -z "$timestamp" ] && continue

        # Extract frame number if present
        frame=$(echo "$line" | grep -oE '\( *[0-9]+\)' | grep -oE '[0-9]+' | head -1)

        # Determine marker type (start = content starts, stop = content stops/ad starts)
        marker_type="mark"
        if echo "$line" | grep -qi "start"; then
            marker_type="start"  # Content starts (ad ends)
        elif echo "$line" | grep -qi "stop"; then
            marker_type="stop"   # Content stops (ad starts)
        fi

        # Check if verified (has *)
        verified=""
        echo "$line" | grep -q '\*' && verified="*"

        # Store marker: timestamp|frame|type|verified
        VDR_MARKS+=("$timestamp|${frame:-0}|$marker_type|$verified")

    done < "$MARKS_FILE"

    info "  Found ${#VDR_MARKS[@]} markers"
fi

info "Analyzing: $INPUT"
if $ES_MODE; then
    info "Mode: Elementary Stream (for TTCut)"
else
    info "Mode: Normalized MKV"
fi
echo ""

# Get stream information with language tags
VIDEO_STREAM=""
AUDIO_STREAMS=()
SUBTITLE_STREAMS=()
VIDEO_CODEC=""
VIDEO_WIDTH=""
VIDEO_HEIGHT=""
FRAME_RATE=""

# Get video stream info
VIDEO_INFO=$(ffprobe -v error -select_streams v:0 -show_entries stream=index,codec_name,width,height,r_frame_rate -of csv "$INPUT" 2>&1 | grep "^stream," | head -1)
if [ -n "$VIDEO_INFO" ]; then
    IFS=',' read -r _ idx codec_name width height frame_rate <<< "$VIDEO_INFO"
    VIDEO_STREAM="$idx"
    VIDEO_CODEC="$codec_name"
    VIDEO_WIDTH="$width"
    VIDEO_HEIGHT="$height"
    FRAME_RATE="$frame_rate"
    info "Video stream $idx: $codec_name ${width}x${height} @ ${frame_rate}"
fi

# Get audio streams with language (deduplicate by index, prefer entries with language)
declare -A AUDIO_MAP
while IFS=',' read -r _ idx codec_name lang; do
    [ -z "$idx" ] && continue
    # If we already have this index with a language, skip
    if [ -n "${AUDIO_MAP[$idx]}" ]; then
        # Only replace if current has no language and new one does
        old_lang="${AUDIO_MAP[$idx]##*:}"
        if [ "$old_lang" = "und" ] && [ -n "$lang" ]; then
            AUDIO_MAP[$idx]="$idx:$codec_name:$lang"
        fi
    else
        lang="${lang:-und}"
        AUDIO_MAP[$idx]="$idx:$codec_name:$lang"
    fi
done < <(ffprobe -v error -select_streams a -show_entries stream=index,codec_name:stream_tags=language -of csv "$INPUT" 2>&1 | grep "^stream,")

# Convert map to array, sorted by index
for idx in $(echo "${!AUDIO_MAP[@]}" | tr ' ' '\n' | sort -n); do
    AUDIO_STREAMS+=("${AUDIO_MAP[$idx]}")
    IFS=':' read -r _ codec lang <<< "${AUDIO_MAP[$idx]}"
    info "Audio stream $idx: $codec [$lang]"
done

# Get subtitle streams with language (deduplicate by index, prefer entries with language)
declare -A SUB_MAP
while IFS=',' read -r _ idx codec_name lang; do
    [ -z "$idx" ] && continue
    if [ -n "${SUB_MAP[$idx]}" ]; then
        old_lang="${SUB_MAP[$idx]##*:}"
        if [ "$old_lang" = "und" ] && [ -n "$lang" ]; then
            SUB_MAP[$idx]="$idx:$codec_name:$lang"
        fi
    else
        lang="${lang:-und}"
        SUB_MAP[$idx]="$idx:$codec_name:$lang"
    fi
done < <(ffprobe -v error -select_streams s -show_entries stream=index,codec_name:stream_tags=language -of csv "$INPUT" 2>&1 | grep "^stream,")

for idx in $(echo "${!SUB_MAP[@]}" | tr ' ' '\n' | sort -n); do
    SUBTITLE_STREAMS+=("${SUB_MAP[$idx]}")
    IFS=':' read -r _ codec lang <<< "${SUB_MAP[$idx]}"
    info "Subtitle stream $idx: $codec [$lang]"
done

echo ""

# Check we have video
[ -n "$VIDEO_STREAM" ] || error "No video stream found"

# Determine video extension based on codec
case "$VIDEO_CODEC" in
    h264)
        VIDEO_EXT="264"
        info "Video codec: H.264/AVC"
        ;;
    hevc|h265)
        VIDEO_EXT="265"
        info "Video codec: H.265/HEVC"
        ;;
    mpeg2video)
        VIDEO_EXT="m2v"
        info "Video codec: MPEG-2"
        ;;
    *)
        VIDEO_EXT="$VIDEO_CODEC"
        warn "Video codec $VIDEO_CODEC may not be fully supported"
        ;;
esac

# Get original timestamps and duration for info (from container - fast!)
START_PTS=$(ffprobe -v error -select_streams v:0 -show_entries stream=start_time -of csv "$INPUT" 2>&1 | grep "^stream," | head -1 | cut -d',' -f2)
AUDIO_START_PTS=$(ffprobe -v error -select_streams a:0 -show_entries stream=start_time -of csv "$INPUT" 2>&1 | grep "^stream," | head -1 | cut -d',' -f2)

# Get duration — for VDR multi-file, sum individual segment durations
# (ffprobe with concat protocol only reports first segment's duration)
if [ "$VDR_MULTIFILE" = true ]; then
    CONTAINER_VIDEO_DURATION="0"
    for seg in "${VDR_SEGMENTS[@]}"; do
        seg_dur=$(ffprobe -v error -show_entries format=duration \
            -of default=noprint_wrappers=1:nokey=1 "$seg" 2>/dev/null | grep -E '^[0-9]' || echo "0")
        CONTAINER_VIDEO_DURATION=$(awk "BEGIN {printf \"%.6f\", $CONTAINER_VIDEO_DURATION + $seg_dur}")
    done
    info "Total duration across ${#VDR_SEGMENTS[@]} segments: ${CONTAINER_VIDEO_DURATION}s"
else
    CONTAINER_VIDEO_DURATION=$(ffprobe -v error -show_entries format=duration \
        -of default=noprint_wrappers=1:nokey=1 "$INPUT" 2>/dev/null | grep -E '^[0-9]' || echo "")
    if [ -n "$CONTAINER_VIDEO_DURATION" ]; then
        info "Container duration: ${CONTAINER_VIDEO_DURATION}s"
    fi
fi

info "Original video start time: ${START_PTS:-unknown}s"
info "Original audio start time: ${AUDIO_START_PTS:-unknown}s"
echo ""

#############################################################################
# TIMESTAMP REPAIR (normalize timestamps before demuxing)
# This fixes A/V sync issues similar to ProjectX stream repair
#############################################################################
step "Repairing timestamps (normalizing to start at 0)..."

REPAIRED_INPUT="$OUTDIR/.${BASENAME}_repaired.ts"
_CLEANUP_FILES+=("$REPAIRED_INPUT")

# Calculate A/V offset BEFORE repair (from original file)
# For H.264/H.265: use minimum PTS from first 2 seconds (= first display frame PTS)
# because leading B-frames have lower PTS than the I-frame which comes first in decode order.
# For MPEG-2: use first packet PTS (I-frame); B-frame skipping is handled separately below.
if [ "$VIDEO_CODEC" = "hevc" ] || [ "$VIDEO_CODEC" = "h265" ] || [ "$VIDEO_CODEC" = "h264" ]; then
    ORIG_VIDEO_PTS=$(ffprobe -v error -select_streams v:0 -read_intervals "%+2" \
        -show_entries packet=pts_time -of csv=p=0 "$INPUT" 2>/dev/null | \
        tr -d ',' | sort -n | head -1)
else
    ORIG_VIDEO_PTS=$(ffprobe -v error -select_streams v:0 -show_entries packet=pts_time -of csv=p=0 "$INPUT" 2>/dev/null | head -1 | tr -d ',')
fi
# Per-track audio PTS probe: each track gets its own trim value
declare -a ORIG_AUDIO_PTS_ARR=()   # Original PTS per audio track
declare -a AUDIO_TRIM_SECS=()      # Trim value per audio track
AUDIO_TRIM_SEC="0"                 # Legacy: maximum trim (for B-frame skip base)

for i in "${!AUDIO_STREAMS[@]}"; do
    IFS=':' read -r idx codec lang <<< "${AUDIO_STREAMS[$i]}"
    TRACK_PTS=$(ffprobe -v error -select_streams $idx -show_entries packet=pts_time -of csv=p=0 "$INPUT" 2>/dev/null | head -1 | tr -d ',')
    ORIG_AUDIO_PTS_ARR[$i]="${TRACK_PTS:-0}"

    if [ -n "$ORIG_VIDEO_PTS" ] && [ -n "$TRACK_PTS" ]; then
        TRACK_AHEAD=$(awk "BEGIN {printf \"%.6f\", $ORIG_VIDEO_PTS - $TRACK_PTS}")
        TRACK_AHEAD_MS=$(awk "BEGIN {printf \"%.0f\", ($ORIG_VIDEO_PTS - $TRACK_PTS) * 1000}")

        if awk "BEGIN {exit !($TRACK_AHEAD > 0.01)}"; then
            info "Audio track $idx ($codec [$lang]) starts ${TRACK_AHEAD_MS}ms before video - will trim"
            AUDIO_TRIM_SECS[$i]="$TRACK_AHEAD"
        elif awk "BEGIN {exit !($TRACK_AHEAD < -0.01)}"; then
            warn "Audio track $idx ($codec [$lang]): video starts ${TRACK_AHEAD_MS}ms before audio - may need padding"
            AUDIO_TRIM_SECS[$i]="0"
        else
            AUDIO_TRIM_SECS[$i]="0"
        fi
    else
        AUDIO_TRIM_SECS[$i]="0"
    fi
done

# Legacy AUDIO_TRIM_SEC: use first track's value (for B-frame skip adjustment logging)
if [ ${#AUDIO_TRIM_SECS[@]} -gt 0 ]; then
    AUDIO_TRIM_SEC="${AUDIO_TRIM_SECS[0]}"
fi

# Repair timestamps: generate new PTS, ignore corrupt DTS, shift to start at 0
FFMPEG_LOG="$OUTDIR/.ffmpeg_repair.log"
_CLEANUP_FILES+=("$FFMPEG_LOG")
if ffmpeg -y -v warning -fflags +genpts+igndts "${FFMPEG_INPUT_ARGS[@]}" \
    -c copy \
    -avoid_negative_ts make_zero \
    -map 0:v:0 -map 0:a? \
    "$REPAIRED_INPUT" > "$FFMPEG_LOG" 2>&1; then
    # Show progress line
    grep -E "^(frame=|size=)" "$FFMPEG_LOG" | tail -1 | while IFS= read -r line; do info "$line"; done
    # Show any warnings/errors from ffmpeg
    grep -iE "error|warning|invalid|corrupt|suppress|too many|repeated|mismatch" "$FFMPEG_LOG" | while IFS= read -r line; do warn "ffmpeg: $line"; done
    rm -f "$FFMPEG_LOG"

    # Verify repaired file
    if [ -s "$REPAIRED_INPUT" ]; then
        NEW_VIDEO_PTS=$(ffprobe -v error -select_streams v:0 -show_entries stream=start_time -of csv "$REPAIRED_INPUT" 2>&1 | grep "^stream," | head -1 | cut -d',' -f2)
        NEW_AUDIO_PTS=$(ffprobe -v error -select_streams a:0 -show_entries stream=start_time -of csv "$REPAIRED_INPUT" 2>&1 | grep "^stream," | head -1 | cut -d',' -f2)
        info "Repaired video start time: ${NEW_VIDEO_PTS:-0}s"
        info "Repaired audio start time: ${NEW_AUDIO_PTS:-0}s"

        # Use repaired file for demuxing. Update both $INPUT (for ffprobe
        # paths) and $FFMPEG_INPUT_ARGS (for ffmpeg paths) — the repaired
        # file is a single TS with clean PTS, so the concat-demuxer setup
        # for multi-file recordings is no longer needed past this point.
        INPUT="$REPAIRED_INPUT"
        FFMPEG_INPUT_ARGS=(-i "$REPAIRED_INPUT")
        CLEANUP_REPAIRED=true
    else
        warn "Timestamp repair failed, using original file"
        CLEANUP_REPAIRED=false
    fi
else
    # Show ffmpeg errors
    grep -iE "error|warning|invalid|corrupt|suppress|too many|repeated|mismatch" "$FFMPEG_LOG" | while IFS= read -r line; do warn "ffmpeg: $line"; done
    rm -f "$FFMPEG_LOG"
    warn "Timestamp repair failed, using original file"
    CLEANUP_REPAIRED=false
fi
echo ""

#############################################################################
# ELEMENTARY STREAM MODE
#############################################################################
if $ES_MODE; then
    step "Extracting Elementary Streams..."

    # Detect available CPU cores for parallel processing
    NPROC=$(nproc 2>/dev/null || echo 4)
    info "Using up to $NPROC parallel processes"
    echo ""

    # Note: Video is extracted as-is, audio padding happens after extraction
    # This matches ProjectX's approach of adding audio frames at the end

    # 1. Prepare video extraction parameters
    OUTPUT_VIDEO="$OUTDIR/${BASENAME}.${VIDEO_EXT}"

    # For MPEG-2: Find first I-frame time to skip initial B-frames (like ProjectX)
    # This removes "überflüssige B-Frames" before the first GOP
    VIDEO_START_TIME="0"
    if [ "$VIDEO_CODEC" = "mpeg2video" ]; then
        # Find the PTS of the first I-frame (picture type 1)
        # Use -read_intervals to only analyze first 10 seconds (MUCH faster!)
        FIRST_I_PTS=$(ffprobe -v error -select_streams v:0 \
            -read_intervals "%+10" \
            -show_entries frame=pts_time,pict_type \
            -of csv=p=0 "$INPUT" 2>/dev/null | \
            grep ",I$" | head -1 | cut -d',' -f1)

        if [ -n "$FIRST_I_PTS" ] && [ "$FIRST_I_PTS" != "0" ]; then
            # Check if first frame is NOT an I-frame (i.e., there are leading B-frames)
            FIRST_FRAME_TYPE=$(ffprobe -v error -select_streams v:0 \
                -read_intervals "%+1" \
                -show_entries frame=pict_type \
                -of csv=p=0 "$INPUT" 2>/dev/null | head -1)

            if [ "$FIRST_FRAME_TYPE" != "I" ]; then
                # Count B-frames before first I-frame (only need first 2 seconds)
                B_FRAME_COUNT=$(ffprobe -v error -select_streams v:0 \
                    -read_intervals "%+2" \
                    -show_entries frame=pts_time,pict_type \
                    -of csv=p=0 "$INPUT" 2>/dev/null | \
                    awk -F',' 'BEGIN{count=0} $2=="I"{exit} $2=="B"{count++} END{print count}')

                VIDEO_START_TIME="$FIRST_I_PTS"
                SKIPPED_MS=$(awk "BEGIN {printf \"%.0f\", $FIRST_I_PTS * 1000}")
                info "  Skipping $B_FRAME_COUNT initial B-frame(s) (${SKIPPED_MS}ms) before first I-frame"
            fi
        fi
    fi

    # Adjust audio trim to account for skipped video B-frames
    # If we skipped video by VIDEO_START_TIME, we need to also skip that much audio
    if [ "$VIDEO_START_TIME" != "0" ]; then
        for i in "${!AUDIO_TRIM_SECS[@]}"; do
            AUDIO_TRIM_SECS[$i]=$(awk "BEGIN {printf \"%.6f\", ${AUDIO_TRIM_SECS[$i]} + $VIDEO_START_TIME}")
        done
        # Legacy variable for logging
        AUDIO_TRIM_SEC="${AUDIO_TRIM_SECS[0]}"
        TOTAL_SKIP_MS=$(awk "BEGIN {printf \"%.0f\", $AUDIO_TRIM_SEC * 1000}")
        info "  Total audio trim adjusted (A/V offset + B-frame skip), e.g. track 0: ${TOTAL_SKIP_MS}ms"
    fi

    # 2. Prepare audio extraction parameters (before parallel extraction)
    AUDIO_FILES=()
    declare -A LANG_COUNT  # Track how many times each language appears
    declare -a AUDIO_EXTRACT_SS=()      # -ss value (empty = no trim)
    declare -a AUDIO_EXTRACT_MAPS=()    # Stream map index

    if [ ${#AUDIO_STREAMS[@]} -gt 0 ]; then
        for i in "${!AUDIO_STREAMS[@]}"; do
            IFS=':' read -r idx codec lang <<< "${AUDIO_STREAMS[$i]}"

            # Determine extension
            EXT=$(audio_ext_for_codec "$codec")

            # Include language in filename
            # If same language+extension appears multiple times, add index
            OUTPUT_AUDIO="$OUTDIR/${BASENAME}_${lang}.${EXT}"
            lang_ext_key="${lang}_${EXT}"
            if [ "${LANG_COUNT[$lang_ext_key]:-0}" -gt 0 ]; then
                OUTPUT_AUDIO="$OUTDIR/${BASENAME}_${lang}_${LANG_COUNT[$lang_ext_key]}.${EXT}"
            fi
            LANG_COUNT[$lang_ext_key]=$((${LANG_COUNT[$lang_ext_key]:-0} + 1))

            AUDIO_FILES+=("$OUTPUT_AUDIO")

            # Build extraction command (will be run in parallel).
            # All tracks use FFMPEG_INPUT_ARGS (which is -i $ORIGINAL_INPUT
            # for single-file recordings and -f concat -safe 0 -i $LIST_FILE
            # for VDR multi-file). The per-track variation is only -ss, used
            # when the audio stream starts before the video and we want to
            # trim the lead-in. -ss MUST be after -i for MPEG-TS audio
            # extraction with -c:a copy (decoder-side seek; an input-side
            # seek silently produces identical output here).
            TRACK_TRIM="${AUDIO_TRIM_SECS[$i]:-0}"
            if awk "BEGIN {exit !($TRACK_TRIM > 0.001)}"; then
                AUDIO_EXTRACT_SS+=("$TRACK_TRIM")
            else
                AUDIO_EXTRACT_SS+=("")
            fi
            AUDIO_EXTRACT_MAPS+=("$idx")
        done
    fi

    #############################################################################
    # PARALLEL EXTRACTION: Video + All Audio Tracks simultaneously
    #############################################################################
    step "Extracting video + ${#AUDIO_STREAMS[@]} audio track(s) in parallel..."

    # Create a temporary directory for extraction logs
    EXTRACT_LOG_DIR="$OUTDIR/.extract_logs_$$"
    mkdir -p "$EXTRACT_LOG_DIR"
    _CLEANUP_DIRS+=("$EXTRACT_LOG_DIR")

    # Start video extraction in background
    info "  Video -> $OUTPUT_VIDEO"
    (
        case "$VIDEO_CODEC" in
            h264)
                ffmpeg -y "${FFMPEG_INPUT_ARGS[@]}" \
                    -map 0:$VIDEO_STREAM \
                    -c:v copy \
                    -bsf:v h264_mp4toannexb,filter_units=remove_types=12 \
                    -f h264 \
                    "$OUTPUT_VIDEO" 2>&1
                ;;
            hevc|h265)
                ffmpeg -y "${FFMPEG_INPUT_ARGS[@]}" \
                    -map 0:$VIDEO_STREAM \
                    -c:v copy \
                    -bsf:v hevc_mp4toannexb,filter_units=remove_types=38 \
                    -f hevc \
                    "$OUTPUT_VIDEO" 2>&1
                ;;
            mpeg2video)
                declare -a FFMPEG_ARGS=()
                if [ "$VIDEO_START_TIME" != "0" ]; then
                    FFMPEG_ARGS+=("-ss" "$VIDEO_START_TIME")
                fi
                ffmpeg -y "${FFMPEG_ARGS[@]}" "${FFMPEG_INPUT_ARGS[@]}" \
                    -map 0:$VIDEO_STREAM \
                    -c:v copy \
                    -f mpeg2video \
                    "$OUTPUT_VIDEO" 2>&1
                ;;
            *)
                ffmpeg -y "${FFMPEG_INPUT_ARGS[@]}" \
                    -map 0:$VIDEO_STREAM \
                    -c:v copy \
                    "$OUTPUT_VIDEO" 2>&1
                ;;
        esac
    ) > "$EXTRACT_LOG_DIR/video.log" 2>&1 &
    VIDEO_PID=$!

    # Start all audio extractions in parallel
    AUDIO_PIDS=()
    for i in "${!AUDIO_STREAMS[@]}"; do
        IFS=':' read -r idx codec lang <<< "${AUDIO_STREAMS[$i]}"
        info "  Audio $idx [$lang] -> $(basename "${AUDIO_FILES[$i]}")"

        # Run each audio extraction in background (direct invocation, no eval)
        if [ -n "${AUDIO_EXTRACT_SS[$i]}" ]; then
            ffmpeg -y "${FFMPEG_INPUT_ARGS[@]}" -ss "${AUDIO_EXTRACT_SS[$i]}" \
                -map "0:${AUDIO_EXTRACT_MAPS[$i]}" -c:a copy \
                "${AUDIO_FILES[$i]}" > "$EXTRACT_LOG_DIR/audio_$i.log" 2>&1 &
        else
            ffmpeg -y "${FFMPEG_INPUT_ARGS[@]}" \
                -map "0:${AUDIO_EXTRACT_MAPS[$i]}" -c:a copy \
                "${AUDIO_FILES[$i]}" > "$EXTRACT_LOG_DIR/audio_$i.log" 2>&1 &
        fi
        AUDIO_PIDS+=($!)
    done

    # Wait for all extractions to complete
    info "  Waiting for parallel extraction to complete..."

    # Wait for video
    wait $VIDEO_PID
    VIDEO_EXIT=$?
    if [ $VIDEO_EXIT -eq 0 ]; then
        # MPEG-2: Truncate trailing null bytes from ES file.
        # ffmpeg stream-copy from TS extracts zero-stuffed PES payload,
        # leaving invalid null padding that has no MPEG-2 start codes.
        if [ "$VIDEO_CODEC" = "mpeg2video" ]; then
            TRAILING=$(python3 -c "
import os
with open('$OUTPUT_VIDEO','rb') as f:
    sz=os.fstat(f.fileno()).st_size
    n=0; f.seek(sz-1)
    while n<sz:
        if f.read(1)!=b'\x00': break
        n+=1; f.seek(sz-n-1)
    print(n)" 2>/dev/null || echo 0)
            if [ "$TRAILING" -gt 0 ]; then
                ORIG_SIZE=$(stat -c%s "$OUTPUT_VIDEO")
                TRUNC_SIZE=$((ORIG_SIZE - TRAILING))
                truncate -s "$TRUNC_SIZE" "$OUTPUT_VIDEO"
                info "  Truncated $TRAILING trailing null bytes from MPEG-2 ES"
            fi
        fi
        VIDEO_SIZE=$(stat -c%s "$OUTPUT_VIDEO" 2>/dev/null || echo 0)
        info "  Video done: $(numfmt --to=iec $VIDEO_SIZE)"
    else
        warn "  Video extraction failed (exit code: $VIDEO_EXIT)"
        grep -iE "error|warning|invalid|corrupt|failed|suppress|too many" "$EXTRACT_LOG_DIR/video.log" 2>/dev/null | \
            while IFS= read -r line; do warn "  ffmpeg: $line"; done
        VIDEO_SIZE=$(stat -c%s "$OUTPUT_VIDEO" 2>/dev/null || echo 0)
    fi

    # Wait for all audio extractions
    AUDIO_ERRORS=0
    for i in "${!AUDIO_PIDS[@]}"; do
        wait ${AUDIO_PIDS[$i]}
        if [ $? -ne 0 ]; then
            ((AUDIO_ERRORS++))
            warn "  Audio $i extraction failed"
            grep -iE "error|warning|invalid|corrupt|failed|suppress|too many" "$EXTRACT_LOG_DIR/audio_$i.log" 2>/dev/null | \
                while IFS= read -r line; do warn "  ffmpeg: $line"; done
        fi
    done

    if [ $AUDIO_ERRORS -gt 0 ]; then
        warn "  $AUDIO_ERRORS audio extraction(s) had issues"
    else
        info "  All ${#AUDIO_FILES[@]} audio track(s) extracted"
    fi

    # Clean up log directory
    rm -rf "$EXTRACT_LOG_DIR"
    echo ""

    #########################################################################
    # PTS ANALYSIS
    # Detect extra frames in elementary streams via PTS comparison.
    # Uses ttcut-pts-analyze (replaces ttcut-esrepair).
    #########################################################################
    ES_EXTRA_FRAMES_CSV=""
    if command -v ttcut-pts-analyze >/dev/null 2>&1; then
        info "Running PTS analysis on $ORIGINAL_INPUT ..."
        set +e
        PTS_OUTPUT=$(ttcut-pts-analyze --verbose "$ORIGINAL_INPUT" 2>&1)
        PTS_EXIT=$?
        set -e

        if [ "$PTS_EXIT" -eq 1 ]; then
            ES_EXTRA_FRAMES_CSV=$(echo "$PTS_OUTPUT" | grep -oP '^extra_frames=\K.*' || true)
            if [ -n "$ES_EXTRA_FRAMES_CSV" ]; then
                count=$(echo "$ES_EXTRA_FRAMES_CSV" | tr ',' '\n' | wc -l)
                warn "PTS analysis: $count extra frames detected — stream has defective regions"
            fi
        elif [ "$PTS_EXIT" -eq 2 ]; then
            warn "PTS analysis failed (exit 2)"
        fi
    else
        warn "ttcut-pts-analyze not found, skipping PTS analysis"
    fi

    #########################################################################
    # AC3 HEADER REPAIR
    # Fix corrupt acmod field in DVB AC3 streams (stereo header + 384kbps)
    #########################################################################
    declare -A AC3_FIX_RESULTS  # Track fix results per audio file index
    if $AC3FIX && [ ${#AUDIO_FILES[@]} -gt 0 ]; then
        HAS_AC3=false
        for af in "${AUDIO_FILES[@]}"; do
            [[ "$af" == *.ac3 ]] && HAS_AC3=true && break
        done

        if $HAS_AC3; then
            if command -v ttcut-ac3fix &>/dev/null; then
                step "Checking AC3 headers..."

                for i in "${!AUDIO_FILES[@]}"; do
                    AUDIO_FILE="${AUDIO_FILES[$i]}"
                    [[ "$AUDIO_FILE" != *.ac3 ]] && continue

                    # Analyze: run in analyze mode, capture output
                    ANALYZE_OUT=$(ttcut-ac3fix -a "$AUDIO_FILE" 2>&1)

                    # Extract inconsistent frame count from output
                    INCONSISTENT=$(echo "$ANALYZE_OUT" | grep -oP 'Inconsistent frames:\s+\K[0-9]+' || echo "0")

                    if [ "$INCONSISTENT" -gt 0 ]; then
                        # Decode test: if AC3 decodes fine, skip fix (prevents corrupting valid stereo AC3)
                        if ffmpeg -v error -i "$AUDIO_FILE" -t 2 -f null - 2>/dev/null; then
                            info "  $(basename "$AUDIO_FILE"): $INCONSISTENT inconsistent headers but decode OK — skipping fix"
                            continue
                        fi

                        # Fix: write to temp file, then replace
                        TEMP_FIXED="${AUDIO_FILE}.fixed"
                        if ttcut-ac3fix -F -f "$AUDIO_FILE" "$TEMP_FIXED" 2>&1 | tail -1; then
                            if [ -s "$TEMP_FIXED" ]; then
                                mv "$TEMP_FIXED" "$AUDIO_FILE"
                                info "  $(basename "$AUDIO_FILE"): $INCONSISTENT frames fixed"
                                AC3_FIX_RESULTS[$i]="$INCONSISTENT"
                            else
                                warn "  $(basename "$AUDIO_FILE"): fix produced empty file"
                                rm -f "$TEMP_FIXED"
                            fi
                        else
                            warn "  $(basename "$AUDIO_FILE"): fix failed"
                            rm -f "$TEMP_FIXED"
                        fi
                    else
                        info "  $(basename "$AUDIO_FILE"): headers OK"
                    fi
                done
                echo ""
            else
                warn "ttcut-ac3fix not found in PATH, skipping AC3 header repair"
                echo ""
            fi
        fi
    fi

    # Filler NALUs are stripped automatically during extraction via ffmpeg
    # bitstream filter (filter_units=remove_types=12 for H.264, =38 for HEVC)
    if [ "$VIDEO_CODEC" = "h264" ] || [ "$VIDEO_CODEC" = "hevc" ] || [ "$VIDEO_CODEC" = "h265" ]; then
        FILLER_STRIPPED=true
    else
        FILLER_STRIPPED=false
    fi

    # 2b. Check A/V duration mismatch (like ProjectX does)
    # This detects progressive drift that occurs when audio and video have different durations
    info "Checking A/V duration alignment..."

    # Parse frame rate fraction (e.g., "25/1" or "30000/1001")
    FRAME_RATE_NUM=$(echo "$FRAME_RATE" | cut -d'/' -f1)
    FRAME_RATE_DEN=$(echo "$FRAME_RATE" | cut -d'/' -f2)
    FRAME_RATE_DEN="${FRAME_RATE_DEN:-1}"  # Default to 1 if not fractional

    # Detect interlaced: for PAFF/MBAFF content, ffprobe may report the field
    # rate as r_frame_rate (e.g. 50/1 for 25fps PAFF). The original TS typically
    # reports the correct frame rate (25/1), but the ES after filler stripping
    # may report the field rate (50/1). Only halve if r_frame_rate is actually
    # the field rate (roughly 2x the expected frame rate).
    if $ES_MODE; then
        FIELD_ORDER=$(ffprobe -v error -select_streams v:0 \
            -show_entries stream=field_order \
            -of default=noprint_wrappers=1:nokey=1 "$OUTPUT_VIDEO" 2>/dev/null)

        if [[ -n "$FIELD_ORDER" && "$FIELD_ORDER" != "progressive" && "$FIELD_ORDER" != "unknown" ]]; then
            # Check if FRAME_RATE is actually the field rate by comparing with
            # avg_frame_rate from the ES. If r_frame_rate ≈ 2 × avg_frame_rate,
            # then r_frame_rate is the field rate and needs halving.
            AVG_FPS=$(ffprobe -v error -select_streams v:0 \
                -show_entries stream=avg_frame_rate \
                -of default=noprint_wrappers=1:nokey=1 "$OUTPUT_VIDEO" 2>/dev/null)
            AVG_NUM=$(echo "$AVG_FPS" | cut -d'/' -f1)
            AVG_DEN=$(echo "$AVG_FPS" | cut -d'/' -f2)
            AVG_DEN="${AVG_DEN:-1}"

            # Calculate ratio: r_frame_rate / avg_frame_rate
            # If ≈ 2.0, then r_frame_rate is the field rate → halve it
            if [[ -n "$AVG_NUM" && "$AVG_NUM" -gt 0 && "$AVG_DEN" -gt 0 ]]; then
                RATIO=$(awk "BEGIN {printf \"%.1f\", ($FRAME_RATE_NUM / $FRAME_RATE_DEN) / ($AVG_NUM / $AVG_DEN)}")
                if [[ "$RATIO" == "2.0" ]]; then
                    ORIG_RATE="$FRAME_RATE_NUM/$FRAME_RATE_DEN"
                    FRAME_RATE_NUM=$((FRAME_RATE_NUM / 2))
                    FRAME_RATE="${FRAME_RATE_NUM}/${FRAME_RATE_DEN}"
                    info "  Interlaced ($FIELD_ORDER): corrected field rate $ORIG_RATE to frame rate $FRAME_RATE"
                else
                    info "  Interlaced ($FIELD_ORDER): r_frame_rate=$FRAME_RATE_NUM/$FRAME_RATE_DEN is already frame rate (ratio=$RATIO)"
                fi
            fi
        fi
    fi

    # Get video duration - use container duration if available (FAST)
    # Otherwise fall back to probing elementary stream (slow)
    if [ -n "$CONTAINER_VIDEO_DURATION" ]; then
        # Use duration from original container (already obtained earlier - instant!)
        VIDEO_DURATION="$CONTAINER_VIDEO_DURATION"
    else
        # Fallback: probe elementary stream (slower)
        VIDEO_DURATION=$(ffprobe -v error \
            -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 \
            "$OUTPUT_VIDEO" 2>/dev/null | grep -E '^[0-9]' || echo "")

        if [ -z "$VIDEO_DURATION" ] || [ "$VIDEO_DURATION" = "N/A" ]; then
            # Estimate from file size and bitrate (rough approximation)
            VIDEO_SIZE_BYTES=$(stat -c%s "$OUTPUT_VIDEO" 2>/dev/null || echo 0)
            # Assume ~5 Mbit/s for SD, ~15 Mbit/s for HD
            if [ "$VIDEO_WIDTH" -gt 1280 ]; then
                EST_BITRATE=15000000  # 15 Mbit/s for HD
            else
                EST_BITRATE=5000000   # 5 Mbit/s for SD
            fi
            VIDEO_DURATION=$(awk "BEGIN {printf \"%.3f\", $VIDEO_SIZE_BYTES * 8 / $EST_BITRATE}")
            warn "  Duration estimated from file size (may be inaccurate)"
        fi
    fi

    VIDEO_DURATION_MS=$(awk "BEGIN {printf \"%.0f\", $VIDEO_DURATION * 1000}")
    # Calculate approximate frame count from duration (for info file)
    VIDEO_FRAME_COUNT=$(awk "BEGIN {printf \"%.0f\", $VIDEO_DURATION * $FRAME_RATE_NUM / $FRAME_RATE_DEN}")

    # Check first audio file for duration comparison
    AUDIO_DURATION_MS=0
    AV_DRIFT_MS=0
    AV_DRIFT_RATE=0
    if [ ${#AUDIO_FILES[@]} -gt 0 ]; then
        FIRST_AUDIO="${AUDIO_FILES[0]}"
        AUDIO_DURATION=$(ffprobe -v error -show_entries format=duration \
            -of default=noprint_wrappers=1:nokey=1 "$FIRST_AUDIO" 2>/dev/null || echo "0")
        AUDIO_DURATION_MS=$(awk "BEGIN {printf \"%.0f\", $AUDIO_DURATION * 1000}")

        # Calculate drift
        AV_DRIFT_MS=$(awk "BEGIN {printf \"%.0f\", $VIDEO_DURATION_MS - $AUDIO_DURATION_MS}")

        info "  Video: $VIDEO_FRAME_COUNT frames = ${VIDEO_DURATION_MS}ms"
        info "  Audio: ${AUDIO_DURATION_MS}ms"
        info "  Duration difference: ${AV_DRIFT_MS}ms"

        # Calculate drift rate (ms per minute)
        if [ "$VIDEO_DURATION_MS" -gt 0 ]; then
            AV_DRIFT_RATE=$(awk "BEGIN {printf \"%.2f\", $AV_DRIFT_MS / ($VIDEO_DURATION_MS / 60000)}")
            info "  Drift rate: ${AV_DRIFT_RATE}ms/min"
        fi

        # === Audio-Gap Detection, Classification, and Mid-Stream Repair (Rev 2) ===
        # Detect audio packet gaps per track. For each gap, compute how many ms of
        # silence to insert to keep A/V sync: silence_ms = audio_gap_ms minus the
        # video content that was also lost in the same PTS range.
        # Video gaps are detected ONCE per recording (not per audio track).

        VIDEO_GAPS_FILE="$OUTDIR/.video_gaps.txt"
        _CLEANUP_FILES+=("$VIDEO_GAPS_FILE")
        detect_video_gaps "$ORIGINAL_INPUT" "$VIDEO_GAPS_FILE"

        # Parse frame rate to decimal for awk arithmetic
        _FR_NUM=$(echo "$FRAME_RATE" | cut -d'/' -f1)
        _FR_DEN=$(echo "$FRAME_RATE" | cut -d'/' -f2)
        _FR_DEN="${_FR_DEN:-1}"
        FRAME_RATE_DEC=$(awk "BEGIN {printf \"%.6f\", $_FR_NUM / $_FR_DEN}")

        GAP_FILES=()
        CLASSIFIED_FILES=()
        HAS_ANY_SILENCE_NEEDED=false
        AUDIO_GAP_FRAMES_SOURCE_PTS=()  # entries: "src_start src_end silence_ms"
        for i in "${!AUDIO_FILES[@]}"; do
            IFS=':' read -r idx _ _ <<< "${AUDIO_STREAMS[$i]}"
            GAP_FILE="$OUTDIR/.gaps_track_${i}.txt"
            CLASSIFIED_FILE="$OUTDIR/.classified_track_${i}.txt"
            _CLEANUP_FILES+=("$GAP_FILE" "$CLASSIFIED_FILE")
            detect_audio_gaps "$ORIGINAL_INPUT" "$idx" "$GAP_FILE"
            GAP_FILES[$i]="$GAP_FILE"
            : > "$CLASSIFIED_FILE"
            CLASSIFIED_FILES[$i]="$CLASSIFIED_FILE"

            if [ -s "$GAP_FILE" ]; then
                while IFS=' ' read -r gs ge gms; do
                    silence_ms=$(compute_audio_gap_silence_ms "$gs" "$ge" "$VIDEO_GAPS_FILE" "$FRAME_RATE_DEC")
                    echo "$gs $ge $gms $silence_ms" >> "$CLASSIFIED_FILE"
                    AUDIO_GAP_FRAMES_SOURCE_PTS+=("$gs $ge $silence_ms")
                    if [ "$silence_ms" -gt 0 ]; then
                        HAS_ANY_SILENCE_NEEDED=true
                    fi
                done < "$GAP_FILE"
            fi

            # Add per-segment-boundary entries for VDR multi-file recordings.
            # Each boundary mismatch (audio segment shorter or longer than
            # corresponding video segment) yields one row that the same
            # repair_audio_with_silence_inserts and audio_gap_frames= emission
            # paths handle alongside the audio-gap-fix entries above.
            if [ "$VDR_MULTIFILE" = true ]; then
                local_track_trim="${AUDIO_TRIM_SECS[$i]:-0}"
                local_track_pts="${ORIG_AUDIO_PTS_ARR[$i]:-0}"
                while IFS=' ' read -r b_start b_end b_gap b_silence; do
                    [ -z "$b_start" ] && continue
                    [ -z "$b_silence" ] && continue
                    echo "$b_start $b_end $b_gap $b_silence" >> "$CLASSIFIED_FILE"
                    AUDIO_GAP_FRAMES_SOURCE_PTS+=("$b_start $b_end $b_silence")
                    if [ "$b_silence" -ne 0 ]; then
                        HAS_ANY_SILENCE_NEEDED=true
                    fi
                done < <(detect_segment_boundaries "$idx" "$local_track_trim" "$local_track_pts" 5)
            fi
        done

        if [ ${#AUDIO_GAP_FRAMES_SOURCE_PTS[@]} -gt 0 ]; then
            N_NO_SILENCE=0
            N_WITH_SILENCE=0
            for cf in "${CLASSIFIED_FILES[@]}"; do
                [ -s "$cf" ] || continue
                while IFS=' ' read -r _gs _ge _gms sms; do
                    if [ "${sms:-0}" = "0" ]; then
                        N_NO_SILENCE=$(( N_NO_SILENCE + 1 ))
                    else
                        N_WITH_SILENCE=$(( N_WITH_SILENCE + 1 ))
                    fi
                done < "$cf"
            done
            info "  Audio gaps detected across all tracks: $N_NO_SILENCE pure A+V, $N_WITH_SILENCE needing silence"
        fi

        if $HAS_ANY_SILENCE_NEEDED; then
            info "  Inserting silence for gaps with audio loss exceeding video loss..."
            for i in "${!AUDIO_FILES[@]}"; do
                # Check if any gap in this track needs silence (silence_ms > 0)
                NEEDS_REPAIR=false
                while IFS=' ' read -r _gs _ge _gms sms; do
                    if [ "${sms:-0}" != "0" ]; then
                        NEEDS_REPAIR=true
                        break
                    fi
                done < "${CLASSIFIED_FILES[$i]}"

                if $NEEDS_REPAIR; then
                    AUDIO_FILE="${AUDIO_FILES[$i]}"
                    FIRST_AUDIO_PTS_TRACK="${ORIG_AUDIO_PTS_ARR[$i]:-0}"
                    EFFECTIVE_FIRST_AUDIO_PTS=$(awk "BEGIN {a=$FIRST_AUDIO_PTS_TRACK; v=${FIRST_VIDEO_PTS:-0}; printf \"%.6f\", (a > v) ? a : v}")
                    if repair_audio_with_silence_inserts "$AUDIO_FILE" "${CLASSIFIED_FILES[$i]}" "$EFFECTIVE_FIRST_AUDIO_PTS"; then
                        N_REPAIRED=0
                        while IFS=' ' read -r _gs _ge _gms sms; do
                            [ "${sms:-0}" != "0" ] && N_REPAIRED=$(( N_REPAIRED + 1 ))
                        done < "${CLASSIFIED_FILES[$i]}"
                        info "    $(basename "$AUDIO_FILE"): $N_REPAIRED silence-insertion(s) applied"
                    else
                        warn "    $(basename "$AUDIO_FILE"): silence-insert FAILED — leaving original"
                    fi
                fi
            done

            # Recalculate AV_DRIFT_MS after repair so the end-pad block below
            # operates on the residual drift only.
            FIRST_AUDIO="${AUDIO_FILES[0]}"
            AUDIO_DURATION=$(ffprobe -v error -show_entries format=duration \
                -of default=noprint_wrappers=1:nokey=1 "$FIRST_AUDIO" 2>/dev/null || echo "0")
            AUDIO_DURATION_MS=$(awk "BEGIN {printf \"%.0f\", $AUDIO_DURATION * 1000}")
            AV_DRIFT_MS=$(awk "BEGIN {printf \"%.0f\", $VIDEO_DURATION_MS - $AUDIO_DURATION_MS}")
            info "  After silence-insertion: Audio=${AUDIO_DURATION_MS}ms, residual drift=${AV_DRIFT_MS}ms"
        elif [ ${#AUDIO_GAP_FRAMES_SOURCE_PTS[@]} -gt 0 ]; then
            info "  All audio gaps perfectly synchronized with video gaps — no silence insertion needed"
        fi

        # Cleanup gap detection files (handled by _CLEANUP_FILES on exit)

        # If video is longer than audio, pad audio with silence (like ProjectX does)
        # This ensures A/V sync throughout the file
        if [ "$AV_DRIFT_MS" -gt 20 ]; then
            info "  Padding ${#AUDIO_FILES[@]} audio track(s) in parallel to match video duration..."

            # Calculate target duration in seconds
            TARGET_AUDIO_DUR=$(awk "BEGIN {printf \"%.6f\", $VIDEO_DURATION_MS / 1000}")

            # Create temp directory for padding logs
            PAD_LOG_DIR="$OUTDIR/.pad_logs_$$"
            mkdir -p "$PAD_LOG_DIR"
            _CLEANUP_DIRS+=("$PAD_LOG_DIR")

            # Start all audio padding in parallel
            # Strategy: Generate silence separately, then concatenate with original
            # using ffmpeg concat demuxer + stream copy. This preserves original
            # AC3 frames bit-for-bit (including per-frame acmod/channel changes).
            PAD_PIDS=()
            for i in "${!AUDIO_FILES[@]}"; do
                AUDIO_FILE="${AUDIO_FILES[$i]}"
                AUDIO_EXT="${AUDIO_FILE##*.}"
                TEMP_PADDED="$OUTDIR/.temp_padded_${i}.${AUDIO_EXT}"
                TEMP_SILENCE="$OUTDIR/.temp_silence_${i}.${AUDIO_EXT}"
                TEMP_CONCAT="$OUTDIR/.temp_concat_${i}.txt"
                _CLEANUP_FILES+=("$TEMP_PADDED" "$TEMP_SILENCE" "$TEMP_CONCAT")

                # Get audio codec, bitrate, channels, and sample rate from original
                AUDIO_CODEC=$(ffprobe -v error -select_streams a:0 \
                    -show_entries stream=codec_name -of default=noprint_wrappers=1:nokey=1 \
                    "$AUDIO_FILE" 2>/dev/null || echo "copy")
                ORIG_BITRATE=$(ffprobe -v error -select_streams a:0 \
                    -show_entries stream=bit_rate -of default=noprint_wrappers=1:nokey=1 \
                    "$AUDIO_FILE" 2>/dev/null)
                ORIG_CHANNELS=$(ffprobe -v error -select_streams a:0 \
                    -show_entries stream=channels -of default=noprint_wrappers=1:nokey=1 \
                    "$AUDIO_FILE" 2>/dev/null)
                ORIG_SAMPLE_RATE=$(ffprobe -v error -select_streams a:0 \
                    -show_entries stream=sample_rate -of default=noprint_wrappers=1:nokey=1 \
                    "$AUDIO_FILE" 2>/dev/null)
                ORIG_DURATION=$(ffprobe -v error -show_entries format=duration \
                    -of default=noprint_wrappers=1:nokey=1 "$AUDIO_FILE" 2>/dev/null || echo "0")
                # Clear non-numeric values (e.g. "N/A") so fallback defaults trigger
                [[ "$ORIG_BITRATE" =~ ^[0-9]+$ ]] || ORIG_BITRATE=""
                [[ "$ORIG_CHANNELS" =~ ^[0-9]+$ ]] || ORIG_CHANNELS=""
                [[ "$ORIG_SAMPLE_RATE" =~ ^[0-9]+$ ]] || ORIG_SAMPLE_RATE=""

                # Calculate padding duration
                PAD_DURATION=$(awk "BEGIN {d = $TARGET_AUDIO_DUR - $ORIG_DURATION; printf \"%.6f\", (d > 0) ? d : 0}")

                # Choose encoder for silence generation (matching original format)
                case "$AUDIO_CODEC" in
                    mp2)
                        ENCODER="-c:a mp2 -b:a ${ORIG_BITRATE:-192000} -ac ${ORIG_CHANNELS:-2}"
                        ;;
                    ac3)
                        ENCODER="-c:a ac3 -b:a ${ORIG_BITRATE:-384000} -ac ${ORIG_CHANNELS:-2}"
                        ;;
                    aac)
                        ENCODER="-c:a aac -b:a ${ORIG_BITRATE:-192000} -ac ${ORIG_CHANNELS:-2}"
                        ;;
                    *)
                        ENCODER="-c:a copy"
                        ;;
                esac

                # Run padding in background
                (
                    # 1. Generate silence matching original audio format
                    ffmpeg -y -f lavfi \
                        -i "anullsrc=r=${ORIG_SAMPLE_RATE:-48000}:cl=${ORIG_CHANNELS:-2}c" \
                        -t "$PAD_DURATION" \
                        $ENCODER \
                        "$TEMP_SILENCE" 2>&1

                    # 2. Concatenate original + silence via concat demuxer (stream copy)
                    printf "file '%s'\nfile '%s'\n" "$AUDIO_FILE" "$TEMP_SILENCE" > "$TEMP_CONCAT"
                    ffmpeg -y -f concat -safe 0 -i "$TEMP_CONCAT" \
                        -c:a copy \
                        "$TEMP_PADDED" 2>&1

                    rm -f "$TEMP_SILENCE" "$TEMP_CONCAT"
                ) > "$PAD_LOG_DIR/pad_$i.log" 2>&1 &
                PAD_PIDS+=($!)
            done

            # Wait for all padding to complete and process results
            for i in "${!PAD_PIDS[@]}"; do
                wait ${PAD_PIDS[$i]}
                PAD_EXIT=$?

                AUDIO_FILE="${AUDIO_FILES[$i]}"
                AUDIO_EXT="${AUDIO_FILE##*.}"
                TEMP_PADDED="$OUTDIR/.temp_padded_${i}.${AUDIO_EXT}"

                if [ $PAD_EXIT -eq 0 ] && [ -s "$TEMP_PADDED" ]; then
                    # Get original duration for comparison
                    ORIG_DUR=$(ffprobe -v error -show_entries format=duration \
                        -of default=noprint_wrappers=1:nokey=1 "$AUDIO_FILE" 2>/dev/null || echo "0")
                    ORIG_DUR_MS=$(awk "BEGIN {printf \"%.0f\", $ORIG_DUR * 1000}")

                    # Replace original with padded version
                    mv "$TEMP_PADDED" "$AUDIO_FILE"

                    # Calculate how much was added
                    NEW_DURATION=$(ffprobe -v error -show_entries format=duration \
                        -of default=noprint_wrappers=1:nokey=1 "$AUDIO_FILE" 2>/dev/null || echo "0")
                    NEW_DURATION_MS=$(awk "BEGIN {printf \"%.0f\", $NEW_DURATION * 1000}")
                    ADDED_MS=$((NEW_DURATION_MS - ORIG_DUR_MS))

                    info "    $(basename "$AUDIO_FILE"): +${ADDED_MS}ms padding"
                else
                    warn "    Failed to pad $(basename "$AUDIO_FILE")"
                    grep -iE "error|warning|invalid|corrupt|failed|suppress|too many" "$PAD_LOG_DIR/pad_$i.log" 2>/dev/null | \
                        while IFS= read -r line; do warn "    ffmpeg: $line"; done
                    rm -f "$TEMP_PADDED"
                fi
            done

            # Clean up log directory
            rm -rf "$PAD_LOG_DIR"

            # Recalculate drift after padding
            FIRST_AUDIO="${AUDIO_FILES[0]}"
            AUDIO_DURATION=$(ffprobe -v error -show_entries format=duration \
                -of default=noprint_wrappers=1:nokey=1 "$FIRST_AUDIO" 2>/dev/null || echo "0")
            AUDIO_DURATION_MS=$(awk "BEGIN {printf \"%.0f\", $AUDIO_DURATION * 1000}")
            AV_DRIFT_MS=$(awk "BEGIN {printf \"%.0f\", $VIDEO_DURATION_MS - $AUDIO_DURATION_MS}")
            # Recalculate drift rate with corrected values
            AV_DRIFT_RATE=$(awk "BEGIN {printf \"%.2f\", $AV_DRIFT_MS / ($VIDEO_DURATION_MS / 60000)}")

            info "  After padding: Video=${VIDEO_DURATION_MS}ms, Audio=${AUDIO_DURATION_MS}ms, Drift=${AV_DRIFT_MS}ms"
        elif [ "${AV_DRIFT_MS#-}" -gt 50 ]; then
            # Negative drift (audio longer than video) - warn but don't fix
            warn "  A/V duration mismatch detected!"
            warn "  Audio is longer than video by ${AV_DRIFT_MS#-}ms"
            warn "  This may cause issues at the end of playback."
        else
            info "  A/V sync is good (drift: ${AV_DRIFT_MS}ms)"
        fi
    fi
    echo ""

    # 3. Try to extract subtitles
    SUBTITLE_FILES=()
    if [ ${#SUBTITLE_STREAMS[@]} -gt 0 ]; then
        info "Attempting subtitle extraction..."

        # Get duration for mid-point sampling (subtitles may not exist during pre-roll/ads)
        if [ "$VDR_MULTIFILE" = true ] && [ "$CLEANUP_REPAIRED" != true ]; then
            # Use pre-calculated total duration
            sub_duration="$CONTAINER_VIDEO_DURATION"
        else
            sub_duration=$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$INPUT" 2>/dev/null | head -1)
        fi
        sub_midpoint=$(awk "BEGIN {printf \"%.0f\", ${sub_duration:-0} / 2}")
        [ "$sub_midpoint" -lt 60 ] 2>/dev/null && sub_midpoint=0

        for sub in "${SUBTITLE_STREAMS[@]}"; do
            IFS=':' read -r idx codec lang <<< "$sub"

            # Quick check: does the stream contain data? (sample 120s from mid-point)
            sub_packets=$(timeout 30 ffprobe -v error -read_intervals "${sub_midpoint}%+120" \
                -select_streams 0:$idx -show_entries packet=size \
                -of csv=p=0 "$INPUT" 2>/dev/null | head -1)
            if [ -z "$sub_packets" ]; then
                info "  Subtitle $idx [$lang] ($codec) - empty, skipped"
                continue
            fi

            case "$codec" in
                dvb_subtitle|dvbsub)
                    OUTPUT_SUB="$OUTDIR/${BASENAME}_${lang}.sup"
                    info "  DVB subtitle $idx [$lang] -> $OUTPUT_SUB (bitmap)"
                    ffmpeg -y "${FFMPEG_INPUT_ARGS[@]}" -map 0:$idx -c copy "$OUTPUT_SUB" 2>&1 | grep -E "^(Output|Stream)" || true
                    [ -s "$OUTPUT_SUB" ] && SUBTITLE_FILES+=("$OUTPUT_SUB") || rm -f "$OUTPUT_SUB"
                    ;;
                subrip|srt|text)
                    OUTPUT_SUB="$OUTDIR/${BASENAME}_${lang}.srt"
                    info "  Subtitle $idx [$lang] -> $OUTPUT_SUB"
                    ffmpeg -y "${FFMPEG_INPUT_ARGS[@]}" -map 0:$idx "$OUTPUT_SUB" 2>&1 | grep -E "^(Output|Stream)" || true
                    SUBTITLE_FILES+=("$OUTPUT_SUB")
                    ;;
                *)
                    warn "  Subtitle $idx [$lang]: $codec - not supported"
                    ;;
            esac
        done
        echo ""
    fi

    # 4. Calculate A/V sync offset
    # Get first packet PTS for video and audio from the ORIGINAL input (before repair)
    # The repaired file has timestamps normalized to 0, so we need the original for offset
    info "Calculating A/V sync offset..."

    # Get first display PTS from ORIGINAL file (before timestamp repair)
    # For H.264/H.265: use minimum PTS (first display frame, a B-frame)
    # For MPEG-2: use first packet PTS (I-frame)
    if [ "$VIDEO_CODEC" = "hevc" ] || [ "$VIDEO_CODEC" = "h265" ] || [ "$VIDEO_CODEC" = "h264" ]; then
        FIRST_VIDEO_PTS=$(ffprobe -v error -select_streams v:0 -read_intervals "%+2" \
            -show_entries packet=pts_time -of csv=p=0 "$ORIGINAL_INPUT" 2>/dev/null | \
            tr -d ',' | sort -n | head -1)
    else
        FIRST_VIDEO_PTS=$(ffprobe -v error -select_streams v:0 -show_entries packet=pts_time -of csv=p=0 "$ORIGINAL_INPUT" 2>/dev/null | head -1 | tr -d ',')
    fi
    # Use per-track PTS from earlier probe (ORIG_AUDIO_PTS_ARR)
    # Legacy: FIRST_AUDIO_PTS = first track's PTS (for backwards compat in .info)
    FIRST_AUDIO_PTS="${ORIG_AUDIO_PTS_ARR[0]:-}"

    # Calculate per-track A/V offset and report
    if [ -n "$FIRST_VIDEO_PTS" ]; then
        info "  Original video PTS: ${FIRST_VIDEO_PTS}s"
        for i in "${!AUDIO_STREAMS[@]}"; do
            IFS=':' read -r idx codec lang <<< "${AUDIO_STREAMS[$i]}"
            TRACK_PTS="${ORIG_AUDIO_PTS_ARR[$i]:-}"
            TRACK_TRIM="${AUDIO_TRIM_SECS[$i]:-0}"
            if [ -n "$TRACK_PTS" ]; then
                TRACK_OFFSET_MS=$(awk "BEGIN {printf \"%.0f\", ($TRACK_PTS - $FIRST_VIDEO_PTS) * 1000}")
                TRACK_TRIM_MS=$(awk "BEGIN {printf \"%.0f\", $TRACK_TRIM * 1000}")
                info "  Audio track $idx ($codec [$lang]): PTS=${TRACK_PTS}s offset=${TRACK_OFFSET_MS}ms trimmed=${TRACK_TRIM_MS}ms"
            fi
        done

        # Legacy global av_offset_ms: use first track
        if [ -n "$FIRST_AUDIO_PTS" ]; then
            AV_OFFSET_MS=$(awk "BEGIN {printf \"%.0f\", ($FIRST_AUDIO_PTS - $FIRST_VIDEO_PTS) * 1000}")
            FIRST_TRIM="${AUDIO_TRIM_SECS[0]:-0}"
            if awk "BEGIN {exit !($FIRST_TRIM > 0.01)}"; then
                FIRST_TRIM_MS=$(awk "BEGIN {printf \"%.0f\", $FIRST_TRIM * 1000}")
                AV_OFFSET_MS=$(awk "BEGIN {printf \"%.0f\", $AV_OFFSET_MS + $FIRST_TRIM_MS}")
            fi
            info "  Global av_offset_ms (from track 0): ${AV_OFFSET_MS}ms"
        else
            AV_OFFSET_MS="0"
        fi
    else
        AV_OFFSET="0"
        AV_OFFSET_MS="0"
        warn "  Could not determine A/V offset"
    fi
    echo ""

    # 5. Create info file with metadata
    OUTPUT_INFO="$OUTDIR/${BASENAME}.info"
    info "Creating info file: $OUTPUT_INFO"

    # Calculate trimmed ms for info file
    AUDIO_TRIM_MS=$(awk "BEGIN {printf \"%.0f\", $AUDIO_TRIM_SEC * 1000}")

    cat > "$OUTPUT_INFO" << EOF
# TTCut Elementary Stream Info File
# Generated: $(date -Iseconds)
# Source: $INPUT

[video]
file=${BASENAME}.${VIDEO_EXT}
codec=$VIDEO_CODEC
width=$VIDEO_WIDTH
height=$VIDEO_HEIGHT
frame_rate=$FRAME_RATE
start_pts=$START_PTS
filler_stripped=$FILLER_STRIPPED

[timing]
# A/V sync offset in milliseconds (after correction)
# av_offset_ms = audio_pts - video_pts
# Positive = audio starts AFTER video (audio is too early in ES, delay it)
# Negative = audio starts BEFORE video (audio is too late in ES, advance it)
first_video_pts=$FIRST_VIDEO_PTS
first_audio_pts=$FIRST_AUDIO_PTS
audio_trimmed_ms=$AUDIO_TRIM_MS
# Duration mismatch: positive = video longer than audio (progressive desync)
# Values over 50ms may cause noticeable A/V drift
video_duration_ms=$VIDEO_DURATION_MS
audio_duration_ms=$AUDIO_DURATION_MS
duration_drift_ms=$AV_DRIFT_MS
drift_rate_ms_per_min=$AV_DRIFT_RATE
av_offset_ms=$AV_OFFSET_MS

[audio]
count=${#AUDIO_STREAMS[@]}
EOF

    for i in "${!AUDIO_STREAMS[@]}"; do
        IFS=':' read -r idx codec lang <<< "${AUDIO_STREAMS[$i]}"
        TRACK_TRIM="${AUDIO_TRIM_SECS[$i]:-0}"
        TRACK_TRIM_MS=$(awk "BEGIN {printf \"%.0f\", $TRACK_TRIM * 1000}")
        TRACK_PTS="${ORIG_AUDIO_PTS_ARR[$i]:-}"
        echo "audio_${i}_file=$(basename "${AUDIO_FILES[$i]}" 2>/dev/null || echo "")" >> "$OUTPUT_INFO"
        echo "audio_${i}_codec=$codec" >> "$OUTPUT_INFO"
        echo "audio_${i}_lang=$lang" >> "$OUTPUT_INFO"
        echo "audio_${i}_first_pts=$TRACK_PTS" >> "$OUTPUT_INFO"
        echo "audio_${i}_trimmed_ms=$TRACK_TRIM_MS" >> "$OUTPUT_INFO"
        if [ -n "${AC3_FIX_RESULTS[$i]:-}" ]; then
            echo "audio_${i}_ac3_fixed=true" >> "$OUTPUT_INFO"
            echo "audio_${i}_ac3_fixed_frames=${AC3_FIX_RESULTS[$i]}" >> "$OUTPUT_INFO"
        fi
    done

    cat >> "$OUTPUT_INFO" << EOF

[subtitles]
count=${#SUBTITLE_FILES[@]}
EOF

    for i in "${!SUBTITLE_FILES[@]}"; do
        echo "sub_${i}_file=$(basename "${SUBTITLE_FILES[$i]}")" >> "$OUTPUT_INFO"
    done

    WARNINGS_HEADER_WRITTEN=false
    write_warnings_header_if_needed() {
        if ! $WARNINGS_HEADER_WRITTEN; then
            echo "" >> "$OUTPUT_INFO"
            echo "[warnings]" >> "$OUTPUT_INFO"
            WARNINGS_HEADER_WRITTEN=true
        fi
    }

    if [ -n "$ES_EXTRA_FRAMES_CSV" ]; then
        write_warnings_header_if_needed
        echo "es_extra_frames=$ES_EXTRA_FRAMES_CSV" >> "$OUTPUT_INFO"
    fi

    # Emit audio_gap_frames= as comma-separated frame indices spanning each gap.
    # Uses first_video_pts as reference (consistent with es_extra_frames mapping).
    if [ ${#AUDIO_GAP_FRAMES_SOURCE_PTS[@]} -gt 0 ] && [ -n "$FIRST_VIDEO_PTS" ]; then
        FRAME_RATE_NUM_LOCAL=$(echo "$FRAME_RATE" | cut -d'/' -f1)
        FRAME_RATE_DEN_LOCAL=$(echo "$FRAME_RATE" | cut -d'/' -f2)
        FRAME_RATE_DEN_LOCAL="${FRAME_RATE_DEN_LOCAL:-1}"

        ALL_GAP_FRAMES=()
        for entry in "${AUDIO_GAP_FRAMES_SOURCE_PTS[@]}"; do
            IFS=' ' read -r gs ge silence_ms <<< "$entry"
            gs_frame=$(awk "BEGIN {printf \"%d\", ($gs - $FIRST_VIDEO_PTS) * $FRAME_RATE_NUM_LOCAL / $FRAME_RATE_DEN_LOCAL + 0.5}")
            [ "$gs_frame" -lt 0 ] && gs_frame=0
            # Compute end-frame from silence_ms (at least 1 frame for visibility)
            silence_frames=$(awk "BEGIN {f = $silence_ms / 1000.0 * $FRAME_RATE_NUM_LOCAL / $FRAME_RATE_DEN_LOCAL; printf \"%d\", (f >= 1) ? f : 0}")
            ge_frame=$(( gs_frame + silence_frames ))
            for ((f = gs_frame; f <= ge_frame; f++)); do
                ALL_GAP_FRAMES+=("$f")
            done
        done

        GAP_FRAMES_SORTED=$(printf '%s\n' "${ALL_GAP_FRAMES[@]}" | sort -n -u | paste -sd,)
        if [ -n "$GAP_FRAMES_SORTED" ]; then
            write_warnings_header_if_needed
            echo "audio_gap_frames=$GAP_FRAMES_SORTED" >> "$OUTPUT_INFO"
        fi
    fi

    # Add VDR markers if found
    if [ ${#VDR_MARKS[@]} -gt 0 ]; then
        cat >> "$OUTPUT_INFO" << EOF

[markers]
# VDR markad markers (from: $MARKS_FILE)
# Format: index=timestamp|frame|type|verified
# type: start=content starts (ad ends), stop=content stops (ad starts), mark=unknown
count=${#VDR_MARKS[@]}
EOF
        for i in "${!VDR_MARKS[@]}"; do
            echo "marker_${i}=${VDR_MARKS[$i]}" >> "$OUTPUT_INFO"
        done
        info "  Added ${#VDR_MARKS[@]} VDR markers to info file"
    fi

    # Copy markad logo PGM if available
    pgm_file=$(find "$INPUT_DIR" -maxdepth 1 -name '*-P0.pgm' -type f 2>/dev/null | head -1)
    if [ -n "$pgm_file" ]; then
        logo_dest="${OUTDIR}/${BASENAME}.logo.pgm"
        cp "$pgm_file" "$logo_dest"
        info "Logo PGM copied: $(basename "$pgm_file") -> $(basename "$logo_dest")"
    fi

    echo ""

    # Summary
    echo ""
    info "=== Elementary Stream Demux Complete ==="
    echo ""
    info "Output files:"
    while IFS= read -r line; do
        info "  $line"
    done < <(ls -lh "$OUTDIR/${BASENAME}"* 2>/dev/null | grep -v "^total" || true)
    echo ""
    info "Video for TTCut: $OUTPUT_VIDEO"
    info "Info file: $OUTPUT_INFO"
    if [ ${#AUDIO_FILES[@]} -gt 0 ]; then
        info "Audio files: ${#AUDIO_FILES[@]} track(s)"
    fi

#############################################################################
# MKV MODE (default)
#############################################################################
else
    # Detect available CPU cores for parallel processing
    NPROC=$(nproc 2>/dev/null || echo 4)
    info "Using up to $NPROC parallel processes"

    # Original MKV mode
    if [ ${#AUDIO_STREAMS[@]} -gt 0 ]; then
        IFS=':' read -r FIRST_AUDIO FIRST_CODEC FIRST_LANG <<< "${AUDIO_STREAMS[0]}"
        OUTPUT_MKV="$OUTDIR/${BASENAME}_normalized.mkv"

        step "Creating normalized MKV: $OUTPUT_MKV"
        info "  Video: stream $VIDEO_STREAM"
        info "  Audio: stream $FIRST_AUDIO [$FIRST_LANG]"

        # Check if mkvmerge is available
        if ! command -v mkvmerge &> /dev/null; then
            error "mkvmerge not found. Please install mkvtoolnix package."
        fi

        # First extract video and audio separately with ffmpeg IN PARALLEL
        TEMP_VIDEO="$OUTDIR/.temp_video_$$.mkv"
        TEMP_AUDIO="$OUTDIR/.temp_audio_$$.mka"
        MKV_LOG_DIR="$OUTDIR/.mkv_extract_logs_$$"
        mkdir -p "$MKV_LOG_DIR"
        _CLEANUP_FILES+=("$TEMP_VIDEO" "$TEMP_AUDIO")
        _CLEANUP_DIRS+=("$MKV_LOG_DIR")

        step "Extracting video and audio streams in parallel..."

        # Start video extraction in background; capture stderr so we can
        # diagnose failures instead of silently feeding mkvmerge garbage.
        ffmpeg -y "${FFMPEG_INPUT_ARGS[@]}" \
            -map 0:$VIDEO_STREAM \
            -c copy \
            "$TEMP_VIDEO" > "$MKV_LOG_DIR/video.log" 2>&1 &
        VIDEO_PID=$!

        # Start audio extraction in background
        ffmpeg -y "${FFMPEG_INPUT_ARGS[@]}" \
            -map 0:$FIRST_AUDIO \
            -c copy \
            "$TEMP_AUDIO" > "$MKV_LOG_DIR/audio.log" 2>&1 &
        AUDIO_PID=$!

        # Wait for both to complete and check exit codes — silent failures
        # produced broken MKVs without diagnostics in the past.
        set +e
        wait $VIDEO_PID; VIDEO_EXIT=$?
        wait $AUDIO_PID; AUDIO_EXIT=$?
        set -e

        if [ $VIDEO_EXIT -ne 0 ]; then
            warn "ffmpeg video extraction failed (exit $VIDEO_EXIT):"
            tail -20 "$MKV_LOG_DIR/video.log" | while IFS= read -r line; do warn "  $line"; done
            error "Aborting: video stream extraction failed"
        fi
        info "  Video extraction complete"

        if [ $AUDIO_EXIT -ne 0 ]; then
            warn "ffmpeg audio extraction failed (exit $AUDIO_EXIT):"
            tail -20 "$MKV_LOG_DIR/audio.log" | while IFS= read -r line; do warn "  $line"; done
            error "Aborting: audio stream extraction failed"
        fi
        info "  Audio extraction complete"

        # Use mkvmerge to create the final MKV with bitstream timing fix
        info "  Muxing with mkvmerge (--fix-bitstream-timing-information)..."
        mkvmerge -o "$OUTPUT_MKV" \
            --fix-bitstream-timing-information 0:1 \
            "$TEMP_VIDEO" \
            "$TEMP_AUDIO"

        # Clean up temp files (trap will catch leftovers on abort)
        rm -f "$TEMP_VIDEO" "$TEMP_AUDIO"
        rm -rf "$MKV_LOG_DIR"

        # Verify output
        NEW_START=$(ffprobe -v error -show_entries stream=start_time -of csv "$OUTPUT_MKV" 2>&1 | grep "^stream," | head -1 | cut -d',' -f2)
        info "Normalized start time: ${NEW_START}s"
        echo ""
    fi

    # Extract additional audio tracks IN PARALLEL
    if [ ${#AUDIO_STREAMS[@]} -gt 1 ]; then
        step "Extracting ${#AUDIO_STREAMS[@]} additional audio track(s) in parallel..."
        declare -A LANG_COUNT  # Track how many times each language appears

        # Build list of extraction commands and output files
        EXTRA_AUDIO_FILES=()
        EXTRA_AUDIO_PIDS=()

        for i in "${!AUDIO_STREAMS[@]}"; do
            [ $i -eq 0 ] && continue  # Skip first (already in MKV)

            IFS=':' read -r idx codec lang <<< "${AUDIO_STREAMS[$i]}"

            EXT=$(audio_ext_for_codec "$codec")

            # If same language+extension appears multiple times, add index
            OUTPUT_AUDIO="$OUTDIR/${BASENAME}_${lang}.${EXT}"
            lang_ext_key="${lang}_${EXT}"
            if [ "${LANG_COUNT[$lang_ext_key]:-0}" -gt 0 ]; then
                OUTPUT_AUDIO="$OUTDIR/${BASENAME}_${lang}_${LANG_COUNT[$lang_ext_key]}.${EXT}"
            fi
            LANG_COUNT[$lang_ext_key]=$((${LANG_COUNT[$lang_ext_key]:-0} + 1))

            info "  Audio $idx [$lang] -> $(basename "$OUTPUT_AUDIO")"
            EXTRA_AUDIO_FILES+=("$OUTPUT_AUDIO")

            # Start extraction in background
            ffmpeg -y "${FFMPEG_INPUT_ARGS[@]}" \
                -map 0:$idx \
                -c copy \
                "$OUTPUT_AUDIO" 2>/dev/null &
            EXTRA_AUDIO_PIDS+=($!)
        done

        # Wait for all extractions to complete
        for pid in "${EXTRA_AUDIO_PIDS[@]}"; do
            wait $pid
        done
        info "  All additional audio tracks extracted"
        echo ""
    fi

    # Try to extract subtitles
    if [ ${#SUBTITLE_STREAMS[@]} -gt 0 ]; then
        info "Attempting subtitle extraction..."

        # Get duration for mid-point sampling (subtitles may not exist during pre-roll/ads)
        if [ "$VDR_MULTIFILE" = true ] && [ "$CLEANUP_REPAIRED" != true ]; then
            # Use pre-calculated total duration
            sub_duration="$CONTAINER_VIDEO_DURATION"
        else
            sub_duration=$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$INPUT" 2>/dev/null | head -1)
        fi
        sub_midpoint=$(awk "BEGIN {printf \"%.0f\", ${sub_duration:-0} / 2}")
        [ "$sub_midpoint" -lt 60 ] 2>/dev/null && sub_midpoint=0

        for sub in "${SUBTITLE_STREAMS[@]}"; do
            IFS=':' read -r idx codec lang <<< "$sub"

            # Quick check: does the stream contain data? (sample 120s from mid-point)
            sub_packets=$(timeout 30 ffprobe -v error -read_intervals "${sub_midpoint}%+120" \
                -select_streams 0:$idx -show_entries packet=size \
                -of csv=p=0 "$INPUT" 2>/dev/null | head -1)
            if [ -z "$sub_packets" ]; then
                info "  Subtitle $idx [$lang] ($codec) - empty, skipped"
                continue
            fi

            case "$codec" in
                dvb_subtitle|dvbsub)
                    OUTPUT_SUB="$OUTDIR/${BASENAME}_${lang}.sup"
                    info "  DVB subtitle $idx [$lang] -> $OUTPUT_SUB (bitmap)"
                    ffmpeg -y "${FFMPEG_INPUT_ARGS[@]}" -map 0:$idx -c copy "$OUTPUT_SUB" 2>&1 | grep -E "^(Output|Stream)" || true
                    [ -s "$OUTPUT_SUB" ] || rm -f "$OUTPUT_SUB"
                    ;;
                subrip|srt|text)
                    OUTPUT_SUB="$OUTDIR/${BASENAME}_${lang}.srt"
                    info "  Subtitle $idx [$lang] -> $OUTPUT_SUB"
                    ffmpeg -y "${FFMPEG_INPUT_ARGS[@]}" -map 0:$idx "$OUTPUT_SUB" 2>&1 | grep -E "^(Output|Stream)" || true
                    ;;
                *)
                    warn "Subtitle stream $idx [$lang]: $codec - not supported"
                    ;;
            esac
        done
        echo ""
    fi

    # Summary
    echo ""
    info "=== Demux Complete ==="
    echo ""
    info "Output files:"
    while IFS= read -r line; do
        info "  $line"
    done < <(ls -lh "$OUTDIR/${BASENAME}"* 2>/dev/null | grep -v "^total" || true)
    echo ""
    info "Main file for TTCut: $OUTPUT_MKV"
fi

#############################################################################
# CLEANUP
#############################################################################
# Remove temporary repaired file
if [ "${CLEANUP_REPAIRED:-false}" = "true" ] && [ -f "$REPAIRED_INPUT" ]; then
    rm -f "$REPAIRED_INPUT"
fi
